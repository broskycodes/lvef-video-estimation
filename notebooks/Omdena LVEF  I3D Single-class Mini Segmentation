colab":{"base_uri":"https://localhost:8080/"},"id":"8IpfHvyUSfLM","executionInfo":{"status":"ok","timestamp":1759550703837,"user_tz":420,"elapsed":5344,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"e288c8db-bf7e-4f51-a69c-990ef70e1a29"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Metadata loaded for 10030 videos.\n","[name: \"/device:CPU:0\"\n","device_type: \"CPU\"\n","memory_limit: 268435456\n","locality {\n","}\n","incarnation: 15876761895964080192\n","xla_global_id: -1\n",", name: \"/device:GPU:0\"\n","device_type: \"GPU\"\n","memory_limit: 83112099840\n","locality {\n","  bus_id: 1\n","  links {\n","  }\n","}\n","incarnation: 222498695286607959\n","physical_device_desc: \"device: 0, name: NVIDIA A100-SXM4-80GB, pci bus id: 0000:00:05.0, compute capability: 8.0\"\n","xla_global_id: 416903419\n","]\n","GPU in use: /device:GPU:0\n"]}]},{"cell_type":"code","source":["\n","# ==============================================================================\n","# NEW: DATA PIPELINE FOR MULTI-OUTPUT TFRECORDS\n","# (Replaces your old _parse_regression_tfrecord and make_dataset functions)\n","# ==============================================================================\n","\n","def _parse_multi_output_tfrecord(example):\n","    \"\"\"Parses a single tf.train.Example proto for multi-output training.\"\"\"\n","    feature_description = {\n","        'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","        'label_ef': tf.io.FixedLenFeature([], tf.float32),\n","        'label_mask': tf.io.FixedLenFeature([], tf.string),\n","    }\n","    parsed_example = tf.io.parse_single_example(example, feature_description)\n","\n","    # Parse the video clip\n","    clip = tf.io.parse_tensor(parsed_example['clip_raw'], out_type=tf.float32)\n","    clip = tf.reshape(clip, [FRAMES, SIZE, SIZE, 1])\n","\n","    # Parse the EF label\n","    label_ef = parsed_example['label_ef']\n","\n","    # --- CORRECTED MASK LOGIC ---\n","    # Parse the 3D segmentation mask (height, width, channels)\n","    single_mask = tf.io.parse_tensor(parsed_example['label_mask'], out_type=tf.float32)\n","\n","    # 1. First, expand its dimensions to 4D by adding a new axis at the front\n","    expanded_mask = tf.expand_dims(single_mask, axis=0) # Shape is now (1, height, width, channels)\n","\n","    # 2. Now, tile it along the new 'frames' dimension\n","    label_mask = tf.tile(expanded_mask, [FRAMES, 1, 1, 1]) # Shape is now (FRAMES, height, width, channels)\n","    # --- END OF CORRECTION ---\n","\n","    # Return labels as a dictionary to match the model's output layer names\n","    labels = {\n","        \"ef_output\": label_ef,\n","        \"seg_output\": label_mask\n","    }\n","    return clip, labels\n","\n","def make_multi_output_dataset(split_name, shuffle=False, repeat=False):\n","    \"\"\"Creates a tf.data.Dataset for multi-output from the new .tfrecord files.\"\"\"\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}_multi_output.tfrecord\")\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle:\n","        dataset_size = len(df[df[\"Split\"] == split_name])\n","        dataset = dataset.shuffle(buffer_size=dataset_size)\n","    if repeat:\n","        dataset = dataset.repeat()\n","    dataset = dataset.map(_parse_multi_output_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","# Create the datasets using the new function\n","train_ds = make_multi_output_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_ds   = make_multi_output_dataset(\"VAL\", shuffle=False, repeat=True)\n","test_ds_for_eval = make_multi_output_dataset(\"TEST\", shuffle=False, repeat=False) # Renamed for clarity\n","print(\"Multi-output datasets created successfully.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nY90mywASf5B","executionInfo":{"status":"ok","timestamp":1759550704037,"user_tz":420,"elapsed":173,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"e121a8ce-bb9c-430c-a007-ada3ad0a6213"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Multi-output datasets created successfully.\n"]}]},{"cell_type":"code","source":["# ==============================================================================\n","# METRICS AND CALLBACKS\n","# ==============================================================================\n","\n","import tensorflow.keras.backend as K\n","\n","# Custom R-squared metric (Unchanged)\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    ss_res =  K.sum(K.square(y_true - y_pred))\n","    ss_tot = K.sum(K.square(y_true - K.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + K.epsilon())\n","\n","def dice_coefficient(y_true, y_pred, smooth=1e-6):\n","    \"\"\"Calculates the Dice Similarity Coefficient.\"\"\"\n","    y_true_f = K.flatten(y_true)\n","    y_pred_f = K.flatten(y_pred)\n","    intersection = K.sum(y_true_f * y_pred_f)\n","    return (2. * intersection + smooth) / (K.sum(y_true_f) + K.sum(y_pred_f) + smooth)\n","\n","@tf.keras.utils.register_keras_serializable()\n","def dice_loss(y_true, y_pred):\n","    \"\"\"Calculates Dice Loss from the Dice Coefficient.\"\"\"\n","    return 1 - dice_coefficient(y_true, y_pred)\n","\n","@tf.keras.utils.register_keras_serializable()\n","def dice_bce_loss(y_true, y_pred):\n","    \"\"\"A combined loss function of Dice Loss and Binary Cross-Entropy.\"\"\"\n","    return tf.keras.losses.binary_crossentropy(y_true, y_pred) + dice_loss(y_true, y_pred)\n","\n","# Learning rate scheduler (Unchanged)\n","def lr_step_decay(epoch, lr):\n","    initial_lr = 1e-4 # Your original LR\n","    drop_rate = 0.5\n","    epochs_drop = 10.0\n","    new_lr = initial_lr * (drop_rate ** (epoch // epochs_drop))\n","    return new_lr\n","\n","# Custom callbacks (Unchanged)\n","class MemoryCallback(keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None): self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        mem_info = psutil.Process(os.getpid()).memory_info()\n","        self.max_memory = max(self.max_memory, mem_info.rss)"],"metadata":{"id":"e-BO2vvXSgFA","executionInfo":{"status":"ok","timestamp":1759550704062,"user_tz":420,"elapsed":22,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["# ==============================================================================\n","# NEW: MULTI-OUTPUT I3D MODEL ARCHITECTURE\n","# (Replaces your old build_i3d function)\n","# ==============================================================================\n","\n","# Helper functions for I3D (Unchanged)\n","def conv3d(x, filters, kernel_size, strides=(1, 1, 1), padding='same', use_bias=False, name=None):\n","    x = layers.Conv3D(filters, kernel_size, strides=strides, padding=padding, use_bias=use_bias, name=name)(x)\n","    x = layers.BatchNormalization()(x)\n","    return layers.ReLU()(x)\n","\n","# CORRECTED: Restored your original i3d_inception_module function\n","def i3d_inception_module(x, filters_1x1x1, filters_3x3x3_reduce, filters_3x3x3, filters_3x3x3_double_reduce, filters_3x3x3_double, filters_pool_proj, name=None):\n","    branch1x1x1 = conv3d(x, filters_1x1x1, kernel_size=(1, 1, 1))\n","    branch3x3x3 = conv3d(x, filters_3x3x3_reduce, kernel_size=(1, 1, 1))\n","    branch3x3x3 = conv3d(branch3x3x3, filters_3x3x3, kernel_size=(3, 3, 3))\n","    branch3x3x3dbl = conv3d(x, filters_3x3x3_double_reduce, kernel_size=(1, 1, 1))\n","    branch3x3x3dbl = conv3d(branch3x3x3dbl, filters_3x3x3_double, kernel_size=(3, 3, 3))\n","    branch3x3x3dbl = conv3d(branch3x3x3dbl, filters_3x3x3_double, kernel_size=(3, 3, 3))\n","    branch_pool = layers.MaxPooling3D(pool_size=(3, 3, 3), strides=(1, 1, 1), padding='same')(x)\n","    branch_pool = conv3d(branch_pool, filters_pool_proj, kernel_size=(1, 1, 1))\n","    return layers.concatenate([branch1x1x1, branch3x3x3, branch3x3x3dbl, branch_pool], axis=-1, name=name)\n","\n","def build_i3d_multi_output(input_shape, dropout_rate):\n","    \"\"\"Builds a multi-output I3D model for EF regression and segmentation.\"\"\"\n","    inputs = layers.Input(shape=input_shape)\n","\n","    # --- Shared Backbone (Identical to your original model) ---\n","    x = layers.Conv3D(64, kernel_size=(7, 7, 7), strides=(2, 2, 2), padding='same', name='conv1')(inputs)\n","    x = layers.BatchNormalization(name='bn_conv1')(x)\n","    x = layers.Activation('relu')(x)\n","    x = layers.MaxPooling3D(pool_size=(1, 3, 3), strides=(1, 2, 2), padding='same', name='pool1')(x)\n","    x = layers.Conv3D(192, kernel_size=(3, 3, 3), strides=(1, 1, 1), padding='same', name='conv2')(x)\n","    x = layers.MaxPooling3D(pool_size=(1, 3, 3), strides=(1, 2, 2), padding='same', name='pool2')(x)\n","\n","    x = i3d_inception_module(x, 64, 96, 128, 16, 32, 32, name='inception_3a')\n","    x = i3d_inception_module(x, 128, 128, 192, 32, 96, 64, name='inception_3b')\n","    backbone_output = layers.MaxPooling3D(pool_size=(3, 3, 3), strides=(2, 2, 2), padding='same', name='pool3')(x)\n","    # Shape of backbone_output is (None, 7, 7, 7, C)\n","\n","    # --- Head 1: EF Regression (Identical to your original model) ---\n","    ef_head = layers.GlobalAveragePooling3D(name='ef_gap')(backbone_output)\n","    ef_head = layers.Dropout(dropout_rate, name='ef_dropout')(ef_head)\n","    ef_output = layers.Dense(1, activation='linear', name='ef_output', dtype='float32')(ef_head)\n","\n","    # --- Head 2: Segmentation (Upsampling Path with full layers) ---\n","    # This path is now corrected to fully reconstruct the (28, 112, 112) shape\n","    seg_head = layers.Conv3DTranspose(128, (3, 3, 3), strides=(2, 2, 2), padding='same')(backbone_output) # -> (None, 14, 14, 14, 128)\n","    seg_head = layers.BatchNormalization()(seg_head)\n","    seg_head = layers.ReLU()(seg_head)\n","\n","    seg_head = layers.Conv3DTranspose(64, (3, 3, 3), strides=(2, 2, 2), padding='same')(seg_head) # -> (None, 28, 28, 28, 64)\n","    seg_head = layers.BatchNormalization()(seg_head)\n","    seg_head = layers.ReLU()(seg_head)\n","\n","    seg_head = layers.Conv3DTranspose(32, (3, 3, 3), strides=(1, 2, 2), padding='same')(seg_head) # -> (None, 28, 56, 56, 32)\n","    seg_head = layers.BatchNormalization()(seg_head)\n","    seg_head = layers.ReLU()(seg_head)\n","\n","    # THIS IS THE LAYER THAT WAS MISSING IN THE PREVIOUS VERSION\n","    seg_head = layers.Conv3DTranspose(16, (3, 3, 3), strides=(1, 2, 2), padding='same')(seg_head) # -> (None, 28, 112, 112, 16)\n","    seg_head = layers.BatchNormalization()(seg_head)\n","    seg_head = layers.ReLU()(seg_head)\n","\n","    # Final convolution to produce a single-channel mask.\n","    seg_output = layers.Conv3D(1, (1, 1, 1), activation='sigmoid', padding='same', name='seg_output', dtype='float32')(seg_head)\n","\n","    model = keras.Model(inputs=inputs, outputs={\"ef_output\": ef_output, \"seg_output\": seg_output}, name='i3d_multi_output')\n","    return model"],"metadata":{"id":"UMzOY8B0SgXf","executionInfo":{"status":"ok","timestamp":1759550704086,"user_tz":420,"elapsed":19,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["# ==============================================================================\n","# UPDATED: MODEL COMPILATION WITH NEW LOSS\n","# ==============================================================================\n","\n","strategy = tf.distribute.MirroredStrategy()\n","with strategy.scope():\n","    model = build_i3d_multi_output(\n","        input_shape=(FRAMES, SIZE, SIZE, 1),\n","        dropout_rate=0.5\n","    )\n","\n","    losses = {\n","        \"ef_output\":