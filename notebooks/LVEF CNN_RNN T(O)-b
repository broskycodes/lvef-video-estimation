{"cells":[{"cell_type":"code","source":["## Initial Setup and Configuration\n","import os\n","import datetime\n","import time\n","import psutil\n","import tensorflow as tf\n","from tensorflow import keras\n","import pandas as pd\n","import numpy as np\n","from sklearn.metrics import r2_score as sk_r2_score\n","import matplotlib.pyplot as plt\n","from google.colab import drive\n","import kagglehub\n","\n","# --- Mount Google Drive & Import Data ---\n","drive.mount('/content/drive', force_remount=True)\n","heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-i3d-regression-tfrecord-files')\n","print('Kaggle data sources imported successfully.')\n","\n","# --- Configuration ---\n","DATA_PATH = os.path.join(heartdatabase_path, \"EchoNet-Dynamic\")\n","TFRECORD_PATH = tfrecord_files_path\n","DRIVE_SAVE_PATH = \"/content/drive/My Drive/LVEF Prediction Models/\"\n","FRAMES, SIZE = 28, 112\n","BATCH_SIZE = 8\n","EPOCHS = 50 # Total epochs for both stages combined\n","\n","# --- Performance Optimizations ---\n","tf.keras.mixed_precision.set_global_policy('mixed_float16')\n","tf.config.optimizer.set_jit(True)\n","print(\"TensorFlow performance optimizations enabled.\")\n","\n","df = pd.read_csv(os.path.join(DATA_PATH, \"FileList.csv\"))\n","print(f\"Metadata loaded for {len(df)} videos.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Em59vtbiTmgF","executionInfo":{"status":"ok","timestamp":1756587661351,"user_tz":420,"elapsed":265530,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"8cca8824-f17b-4eca-bd83-160d4263b30f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Warning: Looks like you're using an outdated `kagglehub` version (installed: 0.3.12), please consider upgrading to the latest version (0.3.13).\n","Downloading from https://www.kaggle.com/api/v1/datasets/download/shravansaranyan/lvef-i3d-regression-tfrecord-files?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 3.13G/3.13G [02:28<00:00, 22.5MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Kaggle data sources imported successfully.\n","TensorFlow performance optimizations enabled.\n","Metadata loaded for 10030 videos.\n"]}]},{"cell_type":"code","source":["# --- Custom Metric ---\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    ss_res =  keras.backend.sum(keras.backend.square(y_true - y_pred))\n","    ss_tot = keras.backend.sum(keras.backend.square(y_true - keras.backend.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + keras.backend.epsilon())\n","\n","# --- Custom Memory Callback ---\n","class MemoryCallback(keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        mem_info = psutil.Process(os.getpid()).memory_info()\n","        current_memory = mem_info.rss\n","        self.max_memory = max(self.max_memory, current_memory)"],"metadata":{"id":"M1H_Zb75w7ka"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def _parse_regression_tfrecord(example):\n","    feature_description = {\n","        'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","        'label_ef': tf.io.FixedLenFeature([], tf.float32),\n","    }\n","    example = tf.io.parse_single_example(example, feature_description)\n","    clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","    clip = tf.reshape(clip, [FRAMES, SIZE, SIZE, 1])\n","    clip = tf.repeat(clip, 3, axis=-1)\n","    return clip, example['label_ef']\n","\n","def make_dataset(split_name, shuffle=False, repeat=False):\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}.tfrecord\")\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle:\n","        dataset_size = len(df[df[\"Split\"] == split_name])\n","        dataset = dataset.shuffle(buffer_size=dataset_size)\n","    if repeat:\n","        dataset = dataset.repeat()\n","    dataset = dataset.map(_parse_regression_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","train_ds = make_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_ds   = make_dataset(\"VAL\", shuffle=False, repeat=True)\n","test_ds  = make_dataset(\"TEST\", shuffle=False, repeat=False)\n","print(\"TFRecord data pipelines created successfully.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"3MCJQ3w7VIns","executionInfo":{"status":"ok","timestamp":1756587662809,"user_tz":420,"elapsed":181,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"fc079838-b1fb-4c29-e51c-da9d776f2a0f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["TFRecord data pipelines created successfully.\n"]}]},{"cell_type":"code","source":["# --- NEW: Refactored Model Building Function ---\n","def build_cnnrnn_model():\n","    \"\"\"\n","    Builds the CNN-RNN model architecture.\n","    Returns the complete model and a handle to the CNN base model.\n","    \"\"\"\n","    frame_input_shape = (SIZE, SIZE, 3)\n","    base_model = keras.applications.InceptionV3(\n","        weights=\"imagenet\",\n","        include_top=False,\n","        pooling=\"avg\",\n","        input_shape=frame_input_shape,\n","    )\n","    preprocess_input = keras.applications.inception_v3.preprocess_input\n","    cnn_input = keras.Input(shape=frame_input_shape, name=\"cnn_input\")\n","    preprocessed = preprocess_input(cnn_input)\n","    outputs = base_model(preprocessed)\n","    feature_extractor = keras.Model(cnn_input, outputs, name=\"feature_extractor\")\n","    video_input = keras.Input(shape=(FRAMES, SIZE, SIZE, 3), name=\"video_input\")\n","    time_distributed_features = keras.layers.TimeDistributed(feature_extractor)(video_input)\n","    x = keras.layers.GRU(16, return_sequences=True)(time_distributed_features)\n","    x = keras.layers.GRU(8)(x)\n","    x = keras.layers.Dropout(0.4)(x)\n","    x = keras.layers.Dense(8, activation=\"relu\")(x)\n","    output = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","    model = keras.Model(video_input, output, name=\"cnn_rnn_lvef\")\n","    return model, base_model\n","\n","# Build the model and get a reference to the base\n","# Define the path to your saved model\n","#run_name = \"LVEF CNN_RNN T(O)-b(5)\" # Make sure this is the same run_name\n","#experiment_dir = os.path.join(DRIVE_SAVE_PATH, run_name)\n","#model_path = os.path.join(experiment_dir, \"best_model.keras\")\n","\n","# Load the model, including your custom r2_score function\n","#print(f\"Loading model from: {model_path}\")\n","#model = keras.models.load_model(\n","    #model_path,\n","    #custom_objects={\"r2_score\": r2_score}\n","#)\n","\n","# You still need a reference to the base model for fine-tuning logic\n","#base_model = model.layers[1].layer # This gets the InceptionV3 model inside the TimeDistributed layer"],"metadata":{"id":"-o8OhHwuXNaE"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- Define Training Callbacks ---\n","run_name = \"LVEF CNN_RNN T(O)-b(5)\"\n","experiment_dir = os.path.join(DRIVE_SAVE_PATH, run_name)\n","os.makedirs(experiment_dir, exist_ok=True)\n","print(f\"All outputs for this run will be saved in: {experiment_dir}\")\n","\n","memory_callback = MemoryCallback()\n","callbacks = [\n","    keras.callbacks.ModelCheckpoint(\n","        filepath=os.path.join(experiment_dir, \"best_model.keras\"),\n","        monitor=\"val_rmse\",\n","        save_best_only=True,