\n","--- Generating Output Files ---\n","SUCCESS: Generated 'evaluation_metrics.txt'.\n","SUCCESS: Generated 'performance_analysis_plot.png'.\n","\n","Evaluation complete.\n"]}],"source":["# ==============================================================================\n","# CELL 1: SETUP AND IMPORTS\n","# ==============================================================================\n","import os\n","import datetime\n","import time\n","import psutil\n","import tensorflow as tf\n","from tensorflow import keras\n","import pandas as pd\n","import numpy as np\n","from sklearn.metrics import r2_score as sk_r2_score\n","import matplotlib.pyplot as plt\n","from tqdm import tqdm\n","from google.colab import drive\n","import kagglehub\n","\n","# --- Mount Google Drive & Import Data ---\n","drive.mount('/content/drive', force_remount=True)\n","heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-i3d-regression-tfrecord-files')\n","print('Kaggle data sources imported successfully.')\n","\n","\n","# ==============================================================================\n","# CELL 2: CONFIGURATION\n","# ==============================================================================\n","# --- Configuration ---\n","# IMPORTANT: Set this to the exact name of the model run you want to evaluate.\n","RUN_NAME = \"LVEF CNN_RNN T(O)-a\"\n","\n","DRIVE_SAVE_PATH = \"/content/drive/My Drive/LVEF Prediction Models/\"\n","EXPERIMENT_DIR = os.path.join(DRIVE_SAVE_PATH, RUN_NAME)\n","TFRECORD_PATH = tfrecord_files_path\n","\n","# Video & Batch settings from the training script\n","FRAMES, SIZE = 28, 112\n","BATCH_SIZE = 8 # Used for feature extraction\n","\n","print(f\"--- Preparing to Evaluate Model: {RUN_NAME} ---\")\n","print(f\"--- Loading files from: {EXPERIMENT_DIR} ---\")\n","\n","\n","# ==============================================================================\n","# CELL 3: HELPER FUNCTIONS (DATA PIPELINE & METRICS)\n","# ==============================================================================\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    \"\"\"Custom R2 score metric for Keras.\"\"\"\n","    ss_res =  keras.backend.sum(keras.backend.square(y_true - y_pred))\n","    ss_tot = keras.backend.sum(keras.backend.square(y_true - keras.backend.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + keras.backend.epsilon())\n","\n","def _parse_regression_tfrecord(example):\n","    \"\"\"Parses a TFRecord to produce a 3-channel video tensor.\"\"\"\n","    feature_description = {\n","        'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","        'label_ef': tf.io.FixedLenFeature([], tf.float32),\n","    }\n","    example = tf.io.parse_single_example(example, feature_description)\n","    clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","    clip = tf.reshape(clip, [FRAMES, SIZE, SIZE, 1])\n","    # The CNN was fine-tuned on 3-channel data, so we must repeat the channel here.\n","    clip = tf.repeat(clip, 3, axis=-1)\n","    return clip, example['label_ef']\n","\n","def make_dataset(split_name, batch_size):\n","    \"\"\"Creates a non-repeating tf.data.Dataset for evaluation.\"\"\"\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}.tfrecord\")\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    dataset = dataset.map(_parse_regression_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(batch_size).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","\n","# ==============================================================================\n","# CELL 4: BUILD AND LOAD MODELS\n","# ==============================================================================\n","print(\"\\n--- Building Model Architectures and Loading Weights ---\")\n","\n","# --- Step 1: Re-create the CNN architecture to load the fine-tuned weights ---\n","def build_cnn_only_model():\n","    \"\"\"Rebuilds the exact CNN-only model from the training script.\"\"\"\n","    frame_input_shape = (SIZE, SIZE, 3)\n","    base_model = keras.applications.InceptionV3(\n","        weights=None, # Weights will be loaded manually\n","        include_top=False,\n","        pooling=\"avg\",\n","        input_shape=frame_input_shape,\n","    )\n","    inputs = keras.Input(shape=frame_input_shape)\n","    preprocessed = keras.applications.inception_v3.preprocess_input(inputs)\n","    features = base_model(preprocessed)\n","    x = keras.layers.Dropout(0.5)(features)\n","    outputs = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","    model = keras.Model(inputs, outputs, name=\"cnn_only_finetune\")\n","    return model\n","\n","# --- Step 2: Build the Feature Extractor ---\n","# This model will take videos and run the fine-tuned CNN on each frame.\n","cnn_weights_path = os.path.join(EXPERIMENT_DIR, \"finetuned_cnn_weights.weights.h5\")\n","if not os.path.exists(cnn_weights_path):\n","    raise FileNotFoundError(f\"Required CNN weights not found at: {cnn_weights_path}\")\n","\n","# Build the model and get the InceptionV3 layer\n","temp_cnn_model = build_cnn_only_model()\n","feature_extractor = temp_cnn_model.get_layer('inception_v3')\n","feature_extractor.load_weights(cnn_weights_path)\n","print(\"Successfully loaded fine-tuned CNN weights.\")\n","\n","# Create the final feature extraction model\n","video_input = keras.Input(shape=(FRAMES, SIZE, SIZE, 3))\n","preprocessing_layer = keras.layers.Lambda(keras.applications.inception_v3.preprocess_input)\n","preprocessed_video = keras.layers.TimeDistributed(preprocessing_layer)(video_input)\n","feature_sequences = keras.layers.TimeDistributed(feature_extractor)(preprocessed_video)\n","feature_extraction_model = keras.Model(video_input, feature_sequences)\n","print(\"Feature extraction model built.\")\n","\n","# --- Step 3: Load the final trained RNN model ---\n","rnn_model_path = os.path.join(EXPERIMENT_DIR, \"best_model.keras\")\n","if not os.path.exists(rnn_model_path):\n","    raise FileNotFoundError(f\"Final RNN model not found at: {rnn_model_path}\")\n","\n","final_model = keras.models.load_model(rnn_model_path, custom_objects={\"r2_score\": r2_score})\n","print(\"Successfully loaded final RNN model for evaluation.\")\n","final_model.summary()\n","\n","\n","# ==============================================================================\n","# CELL 5: EXECUTE EVALUATION\n","# ==============================================================================\n","print(\"\\n--- Starting Evaluation ---\")\n","\n","# --- Step 1: Create the test dataset of raw videos ---\n","test_ds_eval = make_dataset(\"TEST\", batch_size=BATCH_SIZE)\n","print(\"Test dataset created.\")\n","\n","# --- Step 2: Extract features from the test set using the fine-tuned CNN ---\n","print(\"Extracting features from the test set... (This may take a moment)\")\n","test_features_list = []\n","test_labels_list = []\n","for videos, labels in tqdm(test_ds_eval):\n","    features = feature_extraction_model.predict(videos, verbose=0)\n","    test_features_list.append(features)\n","    test_labels_list.append(labels.numpy())\n","\n","test_features = np.concatenate(test_features_list)\n","test_labels = np.concatenate(test_labels_list)\n","print(f\"Feature extraction complete. Feature shape: {test_features.shape}\")\n","\n","# --- Step 3: Evaluate the final RNN model on the extracted features ---\n","print(\"\\nEvaluating final model on test set features...\")\n","test_results = final_model.evaluate(test_features, test_labels, return_dict=True)\n","\n","# --- Step 4: Get predictions and calculate R^2 score ---\n","print(\"Generating predictions...\")\n","y_test_pred = final_model.predict(test_features)\n","test_r2 = sk_r2_score(test_labels, y_test_pred)\n","\n","print(\"\\n--- Final Model Metrics (on Test Set) ---\")\n","print(f\"Test RMSE: {test_results['rmse']:.4f}\")\n","print(f\"Test MAE: {test_results['mae']:.4f}\")\n","print(f\"Test R^2: {test_r2:.4f}\")\n","\n","\n","# ==============================================================================\n","# CELL 6: GENERATE OUTPUT FILES\n","# ==============================================================================\n","print(\"\\n--- Generating Output Files ---\")\n","\n","# --- Generate evaluation_metrics.txt ---\n","metrics_path = os.path.join(EXPERIMENT_DIR, \"evaluation_metrics.txt\")\n","with open(metrics_path, 'w') as f:\n","    f.write(f\"Evaluation Metrics for Run: {RUN_NAME}\\n\")\n","    f.write(\"=\"*40 + \"\\n\\n\")\n","    f.write(\"Test Set Metrics:\\n\")\n","    f.write(f\"  - RMSE: {test_results['rmse']:.4f}\\n\")\n","    f.write(f\"  - MAE: {test_results['mae']:.4f}\\n\")\n","    f.write(f\"  - Sklearn R^2: {test_r2:.4f}\\n\")\n","print(f\"SUCCESS: Generated 'evaluation_metrics.txt'.\")\n","\n","# --- Generate performance_analysis_plot.png ---\n","plot_path = os.path.join(EXPERIMENT_DIR, \"performance_analysis_plot.png\")\n","y_true = test_labels.flatten()\n","y_pred = y_test_pred.flatten()\n","\n","fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","\n","# Plot 1: Ground Truth vs. Prediction\n","axes[0].scatter(y_true, y_pred, alpha=0.5)\n","axes[0].plot([y_true.min(), y_true.max()], [y_true.min(), y_true.max()], '--', lw=2, color='red')\n","axes[0].set_xlabel(\"Ground Truth EF (%)\")\n","axes[0].set_ylabel(\"Predicted EF (%)\")\n","axes[0].set_title(\"Prediction vs. Ground Truth\")\n","axes[0].grid(True)\n","\n","# Plot 2: Bland-Altman Plot\n","mean = np.mean([y_true, y_pred], axis=0)\n","diff = y_true - y_pred\n","md = np.mean(diff)\n","sd = np.std(diff, axis=0)\n","axes[1].scatter(mean, diff, alpha=0.5)\n","axes[1].axhline(md, color='gray', linestyle='--')\n","axes[1].axhline(md + 1.96 * sd, color='red', linestyle='--')\n","axes[1].axhline(md - 1.96 * sd, color='red', linestyle='--')\n","axes[1].set_xlabel(\"Average of Ground Truth and Prediction\")\n","axes[1].set_ylabel(\"Difference (Ground Truth - Prediction)\")\n","axes[1].set_title(\"Bland-Altman Plot\")\n","axes[1].grid(True)\n","\n","plt.suptitle(f\"Performance Analysis for {RUN_NAME} (Test Set)\")\n","plt.tight_layout(rect=[0, 0.03, 1, 0.95])\n","fig.savefig(plot_path)\n","plt.close(fig) # Prevent plot from displaying in the notebook\n","print(f\"SUCCESS: Generated 'performance_analysis_plot.png'.\")\n","\n","print(\"\\nEvaluation complete.\")"]}]}