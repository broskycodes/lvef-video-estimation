{"cells":[{"cell_type":"code","source":["# Initial Setup and Configuration\n","\n","import os\n","import datetime\n","import time\n","import psutil\n","\n","import tensorflow as tf\n","from tensorflow import keras\n","import pandas as pd\n","import numpy as np\n","from sklearn.metrics import r2_score as sk_r2_score\n","import matplotlib.pyplot as plt\n","from tqdm import tqdm\n","\n","# --- Mount Google Drive & Import Data ---\n","from google.colab import drive\n","drive.mount('/content/drive', force_remount=True)\n","\n","import kagglehub\n","# NOTE: These paths are sourced from your I3D notebook.\n","# They ensure we use the correct pre-processed TFRecord files.\n","heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-i3d-regression-tfrecord-files')\n","print('Kaggle data sources imported successfully.')\n","\n","\n","# --- Configuration ---\n","DATA_PATH = os.path.join(heartdatabase_path, \"EchoNet-Dynamic\")\n","TFRECORD_PATH = tfrecord_files_path\n","DRIVE_SAVE_PATH = \"/content/drive/My Drive/LVEF Prediction Models/\"\n","\n","# Video & Batch settings consistent with your TFRecord files\n","FRAMES, SIZE = 28, 112\n","# BATCH_SIZE can be tuned. Starting with a slightly larger value than I3D\n","# as this model may be less memory-intensive.\n","BATCH_SIZE = 8\n","EPOCHS = 50\n","\n","# --- Performance Optimizations ---\n","# Use mixed precision for better performance on modern GPUs.\n","tf.keras.mixed_precision.set_global_policy('mixed_float16')\n","# Enable XLA (Accelerated Linear Algebra) for graph optimization.\n","tf.config.optimizer.set_jit(True)\n","print(\"TensorFlow performance optimizations enabled.\")\n","\n","# Load metadata to get dataset sizes for steps_per_epoch calculation later\n","df = pd.read_csv(os.path.join(DATA_PATH, \"FileList.csv\"))\n","print(f\"Metadata loaded for {len(df)} videos.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Em59vtbiTmgF","outputId":"d91db997-ea0f-4a82-e5c6-7b7b8ce56e8b","executionInfo":{"status":"ok","timestamp":1756182204173,"user_tz":420,"elapsed":617949,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}}},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Downloading from https://www.kaggle.com/api/v1/datasets/download/syxlicheng/heartdatabase?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 6.56G/6.56G [05:15<00:00, 22.3MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Downloading from https://www.kaggle.com/api/v1/datasets/download/shravansaranyan/lvef-i3d-regression-tfrecord-files?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 3.13G/3.13G [02:28<00:00, 22.5MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Kaggle data sources imported successfully.\n","TensorFlow performance optimizations enabled.\n","Metadata loaded for 10030 videos.\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"SR4QHlek-pW9","executionInfo":{"status":"ok","timestamp":1756182204178,"user_tz":420,"elapsed":28,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":["def _parse_regression_tfrecord(example):\n","    \"\"\"Parses a single tf.train.Example proto for regression.\"\"\"\n","    feature_description = {\n","        'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","        'label_ef': tf.io.FixedLenFeature([], tf.float32),\n","    }\n","    example = tf.io.parse_single_example(example, feature_description)\n","    clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","    clip = tf.reshape(clip, [FRAMES, SIZE, SIZE, 1])\n","\n","    # This line repeats the single channel 3 times to create an RGB-like image.\n","    clip = tf.repeat(clip, 3, axis=-1)\n","\n","    return clip, example['label_ef']\n","\n","def make_dataset(split_name, shuffle=False, repeat=False):\n","    \"\"\"Creates a tf.data.Dataset from a .tfrecord file.\"\"\"\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}.tfrecord\")\n","\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle:\n","        dataset_size = len(df[df[\"Split\"] == split_name])\n","        dataset = dataset.shuffle(buffer_size=dataset_size)\n","\n","    if repeat:\n","        dataset = dataset.repeat()\n","\n","    dataset = dataset.map(_parse_regression_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","# --- MODIFICATION 1: A NEW DATA PIPELINE FOR FRAMES ---\n","def make_frame_dataset(split_name, shuffle=False, repeat=False):\n","    \"\"\"\n","    Creates a tf.data.Dataset that yields individual frames, not videos.\n","    The LVEF label is duplicated for each frame in a video.\n","    \"\"\"\n","    # Pass the shuffle and repeat arguments to the underlying video dataset\n","    video_ds = make_dataset(split_name, shuffle=shuffle, repeat=repeat)\n","\n","    # Un-batch the videos and labels\n","    video_ds = video_ds.unbatch()\n","\n","    # For each (video, label) pair, create a new dataset of (frame, label) pairs\n","    def create_frame_label_pairs(video, label):\n","        return tf.data.Dataset.from_tensor_slices((video, tf.repeat(label, tf.shape(video)[0])))\n","\n","    frame_ds = video_ds.flat_map(create_frame_label_pairs)\n","\n","    # Re-shuffle at the frame level if requested\n","    if shuffle and repeat: # Shuffling is most effective on a repeating dataset\n","        frame_ds = frame_ds.shuffle(buffer_size=10000)\n","\n","    # Batch the individual frames\n","    frame_ds = frame_ds.batch(BATCH_SIZE * 4).prefetch(tf.data.AUTOTUNE)\n","    return frame_ds\n","\n","print(\"Creating frame-based datasets for CNN fine-tuning...\")\n","train_frame_ds = make_frame_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_frame_ds = make_frame_dataset(\"VAL\")\n"],"metadata":{"id":"3MCJQ3w7VIns","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1756182205725,"user_tz":420,"elapsed":1546,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"a7b3445d-854a-4dd2-9877-66ba4f778a90"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Creating frame-based datasets for CNN fine-tuning...\n"]}]},{"cell_type":"code","source":["# --- Learning Rate Scheduler ---\n","def lr_step_decay(epoch, lr):\n","    \"\"\"Decays the learning rate by a factor of 0.5 every 10 epochs.\"\"\"\n","    initial_lr = 1e-3\n","    drop_rate = 0.5\n","    epochs_drop = 10.0\n","    new_lr = initial_lr * (drop_rate ** (epoch // epochs_drop))\n","    return new_lr\n","\n","# --- Custom Memory Callback ---\n","class MemoryCallback(keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        mem_info = psutil.Process(os.getpid()).memory_info()\n","        current_memory = mem_info.rss\n","        self.max_memory = max(self.max_memory, current_memory)\n","\n","# --- Define Training Callbacks ---\n","# Define a unique name for this experiment run.\n","run_name = \"LVEF CNN_RNN T(O)-a\"\n","experiment_dir = os.path.join(DRIVE_SAVE_PATH, run_name)\n","os.makedirs(experiment_dir, exist_ok=True)\n","print(f\"All outputs for this run will be saved in: {experiment_dir}\")\n","\n","# CNN Weights path\n","cnn_weights_path = os.path.join(experiment_dir, \"finetuned_cnn_weights.weights.h5\")\n","\n","# Custom callback to track peak memory usage.\n","memory_callback = MemoryCallback()\n","\n","# --- Define Callbacks for Stage 1 (CNN) ---\n","# This list is simpler as we only need to log and stop early.\n","cnn_callbacks = [\n","    keras.callbacks.CSVLogger(os.path.join(experiment_dir, \"cnn_training_log.csv\")),\n","    keras.callbacks.EarlyStopping(\n","        monitor=\"val_rmse\",\n","        patience=5, # Shorter patience for the shorter training run\n","        restore_best_weights=True,\n","        verbose=1\n","    ),\n","    memory_callback\n","]\n","\n","# --- Define Callbacks for Stage 2 (RNN) ---\n","# This is your full list of callbacks for the main training stage.\n","rnn_callbacks = [\n","    keras.callbacks.ModelCheckpoint(\n","        filepath=os.path.join(experiment_dir, \"best_rnn_model.keras\"),\n","        monitor=\"val_rmse\",\n","        save_best_only=True,\n","        mode='min',\n","        verbose=1\n","    ),\n","    keras.callbacks.CSVLogger(os.path.join(experiment_dir, \"rnn_training_log.csv\")),\n","    keras.callbacks.EarlyStopping(\n","        monitor=\"val_rmse\",\n","        patience=20,\n","        min_delta=1e-3,\n","        restore_best_weights=True,\n","        verbose=1\n","    ),\n","    keras.callbacks.LearningRateScheduler(lr_step_decay, verbose=1),\n","    memory_callback\n","]\n"],"metadata":{"id":"R6m89B0pBFGZ","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1756182207572,"user_tz":420,"elapsed":1844,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"9b2aa748-11df-49ea-f737-432851454b07"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["All outputs for this run will be saved in: /content/drive/My Drive/LVEF Prediction Models/LVEF CNN_RNN T(O)-a\n"]}]},{"cell_type":"code","source":["# --- MODIFICATION 2: A NEW CNN-ONLY MODEL ---\n","def build_cnn_only_model():\n","    \"\"\"\n","    Builds a model for fine-tuning the CNN on static frames.\n","    \"\"\"\n","    frame_input_shape = (SIZE, SIZE, 3)\n","    base_model = keras.applications.InceptionV3(\n","        weights=\"imagenet\",\n","        include_top=False,\n","        pooling=\"avg\",\n","        input_shape=frame_input_shape,\n","    )\n","\n","    # --- Unfreeze the top layers for fine-tuning ---\n","    fine_tune_at = 'mixed7' # You can adjust this layer name\n","    set_trainable = False\n","    for layer in base_model.layers:\n","        if layer.name == fine_tune_at:\n","            set_trainable = True\n","        if set_trainable:\n","            layer.trainable = True\n","        else:\n","            layer.trainable = False\n","\n","    # --- Add a new regression head ---\n","    inputs = keras.Input(shape=frame_input_shape)\n","    # The InceptionV3 Keras application expects inputs in the range [-1, 1]\n","    preprocessed = keras.applications.inception_v3.preprocess_input(inputs)\n","    features = base_model(preprocessed)\n","    # Add a dropout layer for regularization\n","    x = keras.layers.Dropout(0.5)(features)\n","    # A single output neuron for LVEF prediction\n","    outputs = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","\n","    model = keras.Model(inputs, outputs, name=\"cnn_only_finetune\")\n","    return model\n","\n","cnn_only_model = build_cnn_only_model()\n","\n","\n","# --- MODIFICATION 3: COMPILE AND TRAIN THE CNN-ONLY MODEL ---\n","\n","# Custom R2 metric (same as before)\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    ss_res =  keras.backend.sum(keras.backend.square(y_true - y_pred))\n","    ss_tot = keras.backend.sum(keras.backend.square(y_true - keras.backend.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + keras.backend.epsilon())\n","\n","# Compile with a very low learning rate for fine-tuning\n","cnn_only_model.compile(\n","    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-5),\n","    loss='mse',\n","    metrics=[\n","        tf.keras.metrics.RootMeanSquaredError(name='rmse'),\n","        tf.keras.metrics.MeanAbsoluteError(name='mae'),\n","        r2_score\n","    ]\n",")\n","\n","if os.path.exists(cnn_weights_path):\n","    print(\"--- Stage 1: Found existing CNN weights. Loading them. ---\")\n","    # We still need to build the model to get the feature_extractor layer\n","    cnn_only_model = build_cnn_only_model()\n","    # Get the feature extractor sub-model\n","    feature_extractor = cnn_only_model.get_layer('inception_v3')\n","    # Load the saved weights into it\n","    feature_extractor.load_weights(cnn_weights_path)\n","    print(\"Successfully loaded pre-existing CNN weights.\")\n","else:\n","    print(\"--- Starting Stage 1: Fine-Tuning CNN on individual frames ---\")\n","    # Train for a limited number of epochs\n","    cnn_only_model.fit(\n","        train_frame_ds,\n","        epochs=5, # Fine-tuning for a few epochs is often enough\n","        validation_data=val_frame_ds,\n","        callbacks=cnn_callbacks # Uses CNN callbacks\n","    )\n","\n","    # Save the fine-tuned base model's weights for the next stage\n","    feature_extractor = cnn_only_model.get_layer('inception_v3')\n","    feature_extractor.save_weights(cnn_weights_path)\n","    print(\"Fine-tuned CNN weights saved successfully.\")"],"metadata":{"id":"zyr8HisK-Fz8","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1756182225901,"user_tz":420,"elapsed":18327,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"e5d4e8de-8b3a-4517-f0bd-be9d7521238c"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading data from https://storage.googleapis.com/tensorflow/keras-applications/inception_v3/inception_v3_weights_tf_dim_ordering_tf_kernels_notop.h5\n","\u001b[1m87910968/87910968\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m5s\u001b[0m 0us/step\n","--- Stage 1: Found existing CNN weights. Loading them. ---\n","Successfully loaded pre-existing CNN weights.\n"]}]},{"cell_type":"code","source":["# --- MODIFICATION 4: EXTRACT FEATURES WITH THE FINE-TUNED CNN ---\n","print(\"\\n--- Starting feature extraction with fine-tuned CNN ---\")\n","\n","# --- Create the datasets ---\n","train_ds = make_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_ds   = make_dataset(\"VAL\", shuffle=False, repeat=True)\n","test_ds  = make_dataset(\"TEST\", shuffle=False, repeat=False)\n","\n","# First, build a new feature extractor model and load the weights we just saved\n","feature_extractor = build_cnn_only_model().get_layer('inception_v3')\n","feature_extractor.load_weights(os.path.join(experiment_dir, \"finetuned_cnn_weights.weights.h5\"))\n","\n","# Create a model that takes videos and outputs feature sequences\n","video_input = keras.Input(shape=(FRAMES, SIZE, SIZE, 3), name=\"video_input\")\n","\n","# First, wrap the preprocessing function in a Lambda layer\n","preprocessing_layer = keras.layers.Lambda(\n","    keras.applications.inception_v3.preprocess_input,\n","    name='inception_preprocessing'\n",")\n","\n","# Now, apply the TimeDistributed wrapper to the new *layer*\n","preprocessed_video = keras.layers.TimeDistributed(preprocessing_layer)(video_input)\n","feature_sequences = keras.layers.TimeDistributed(feature_extractor)(preprocessed_video)\n","feature_extraction_model = keras.Model(video_input, feature_sequences)\n","\n","# Helper function to extract and save features\n","def extract_and_save_features(split_name, dataset):\n","    print(f\"Extracting features for {split_name} split...\")\n","    features_list = []\n","    labels_list = []\n","    for videos, labels in tqdm(dataset):\n","        features = feature_extraction_model.predict(videos, verbose=0)\n","        features_list.append(features)\n","        labels_list.append(labels.numpy())\n","\n","    all_features = np.concatenate(features_list)\n","    all_labels = np.concatenate(labels_list)\n","\n","    # Save to disk\n","    np.save(os.path.join(experiment_dir, f\"{split_name}_features.npy\"), all_features)\n","    np.save(os.path.join(experiment_dir, f\"{split_name}_labels.npy\"), all_labels)\n","    print(f\"Saved {split_name} features with shape {all_features.shape}\")\n","    return all_features, all_labels\n","\n","# Create non-repeating datasets for extraction\n","train_video_ds = make_dataset(\"TRAIN\", shuffle=False, repeat=False)\n","val_video_ds = make_dataset(\"VAL\", shuffle=False, repeat=False)\n","\n","# This will take some time to run\n","train_features, train_labels = extract_and_save_features(\"train\", train_video_ds)\n","val_features, val_labels = extract_and_save_features(\"val\", val_video_ds)\n","\n","\n","# --- MODIFICATION 5: A NEW RNN-ONLY MODEL ---\n","def build_rnn_only_model(input_shape):\n","    \"\"\"\n","    Builds the RNN sequence model that takes pre-computed features as input.\n","    \"\"\"\n","    inputs = keras.Input(shape=input_shape)\n","    x = keras.layers.GRU(16, return_sequences=True)(inputs)\n","    x = keras.layers.GRU(8)(x)\n","    x = keras.layers.Dropout(0.4)(x)\n","    x = keras.layers.Dense(8, activation=\"relu\")(x)\n","    outputs = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","    model = keras.Model(inputs, outputs, name=\"rnn_only_model\")\n","    return model\n","\n","rnn_input_shape = (FRAMES, feature_extractor.output_shape[-1])\n","rnn_only_model = build_rnn_only_model(rnn_input_shape)\n","\n","\n","# --- MODIFICATION 6: COMPILE AND TRAIN THE RNN-ONLY MODEL ---\n","rnn_only_model.compile(\n","    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-3),\n","    loss='mse',\n","    metrics=[\n","        tf.keras.metrics.RootMeanSquaredError(name='rmse'),\n","        tf.keras.metrics.MeanAbsoluteError(name='mae'),\n","        r2_score\n","    ]\n",")\n","print(\"\\n--- Starting Stage 2: Training RNN on