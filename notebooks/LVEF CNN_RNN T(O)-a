ts['rmse']:.4f}\")\n","print(f\"Test MAE: {test_results['mae']:.4f}\")\n","print(f\"Test R^2: {test_r2:.4f}\")\n","print(\"\\n--- Performance Metrics (Stage 2 RNN Training) ---\")\n","print(f\"Total Training Time: {readable_total_time}\")\n","print(f\"Average Time per Epoch: {avg_time_per_epoch:.2f} seconds\")\n","print(f\"Maximum RAM Used: {max_ram_gb:.2f} GB\")\n","\n","# --- Generate and Save Analysis Plots ---\n","y_true = test_labels.flatten()\n","y_pred = y_test_pred.flatten()\n","fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","\n","# Plot 1: Ground Truth vs. Prediction\n","axes[0].scatter(y_true, y_pred, alpha=0.5)\n","axes[0].plot([y_true.min(), y_true.max()], [y_true.min(), y_true.max()], '--', lw=2, color='red')\n","axes[0].set_xlabel(\"Ground Truth EF (%)\"); axes[0].set_ylabel(\"Predicted EF (%)\")\n","axes[0].set_title(\"Prediction vs. Ground Truth\"); axes[0].grid(True)\n","\n","# Plot 2: Bland-Altman Plot\n","mean = np.mean([y_true, y_pred], axis=0); diff = y_true - y_pred\n","md = np.mean(diff); sd = np.std(diff, axis=0)\n","axes[1].scatter(mean, diff, alpha=0.5)\n","axes[1].axhline(md, color='gray', linestyle='--')\n","axes[1].axhline(md + 1.96 * sd, color='red', linestyle='--')\n","axes[1].axhline(md - 1.96 * sd, color='red', linestyle='--')\n","axes[1].set_xlabel(\"Average of Ground Truth and Prediction\"); axes[1].set_ylabel(\"Difference (Ground Truth - Prediction)\")\n","axes[1].set_title(\"Bland-Altman Plot\"); axes[1].grid(True)\n","\n","plt.suptitle(\"Model Performance Analysis on Test Set\")\n","plt.tight_layout(rect=[0, 0.03, 1, 0.95])\n","plot_path = os.path.join(experiment_dir, \"performance_analysis_plot.png\")\n","fig.savefig(plot_path)\n","print(f\"Analysis plot saved to: {plot_path}\")\n","plt.show()\n","\n","from google.colab import runtime\n","runtime.unassign()"],"metadata":{"id":"alf4B0DDhNT-","colab":{"base_uri":"https://localhost:8080/","height":0},"executionInfo":{"status":"ok","timestamp":1756183020550,"user_tz":420,"elaps