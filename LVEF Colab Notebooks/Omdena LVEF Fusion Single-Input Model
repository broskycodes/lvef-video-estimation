{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"kiuzuLTfk557"},"outputs":[],"source":["# --- 1. SETUP AND IMPORTS ---\n","import os\n","import shutil\n","import math\n","import time\n","from datetime import datetime, timedelta\n","\n","import numpy as np\n","import pandas as pd\n","import tensorflow as tf\n","from tensorflow import keras\n","from tensorflow.keras import mixed_precision\n","from tensorflow.keras.models import Model\n","from tensorflow.keras.layers import (Input, Conv3D, MaxPooling3D, Flatten, Dense,\n","                                     concatenate, Dropout, ZeroPadding3D, BatchNormalization,\n","                                     LayerNormalization, Activation, Lambda)\n","from tensorflow.keras.regularizers import l1_l2\n","from tensorflow.keras.callbacks import (ModelCheckpoint, CSVLogger, EarlyStopping,\n","                                        TensorBoard, LearningRateScheduler)\n","from sklearn.metrics import r2_score as sk_r2_score\n","from google.colab import drive\n","import kagglehub\n","import matplotlib.pyplot as plt\n","\n","# Suppress TensorFlow/Keras warnings for cleaner output\n","import warnings\n","warnings.filterwarnings(\"ignore\", category=UserWarning)\n","os.environ['TF_CPP_MIN_LOG_LEVEL'] = '2'\n","tf.get_logger().setLevel('ERROR')"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bxWZoLqXk6Ih","executionInfo":{"status":"ok","timestamp":1761331007097,"user_tz":420,"elapsed":403216,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"2736220f-d582-45f1-db23-cfc69665f112"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Connecting to Kaggle datasets...\n","Downloading from https://www.kaggle.com/api/v1/datasets/download/syxlicheng/heartdatabase?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 6.56G/6.56G [02:53<00:00, 40.7MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Downloading from https://www.kaggle.com/api/v1/datasets/download/shravansaranyan/lvef-two-stream-tfrecord-files?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 3.13G/3.13G [01:22<00:00, 40.6MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Dataset connection complete.\n","Running on 1 replicas\n"]}],"source":["# --- 2. CONNECT & CONFIGURE ---\n","drive.mount('/content/drive')\n","print(\"Connecting to Kaggle datasets...\")\n","syxlicheng_heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","shravansaranyan_lvef_two_stream_tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-two-stream-tfrecord-files')\n","print(\"Dataset connection complete.\")\n","\n","mixed_precision.set_global_policy('mixed_float16')\n","tf.config.optimizer.set_jit(True)\n","strategy = tf.distribute.get_strategy()\n","print(f\"Running on {strategy.num_replicas_in_sync} replicas\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"RIM7Q4Z1k6K0"},"outputs":[],"source":["# --- 3. PATHS AND CONSTANTS ---\n","TFRECORD_DIR = shravansaranyan_lvef_two_stream_tfrecord_files_path\n","TRAIN_TFRECORD_PATH = f'{TFRECORD_DIR}/train.tfrecord'\n","VAL_TFRECORD_PATH = f'{TFRECORD_DIR}/val.tfrecord'\n","TEST_TFRECORD_PATH = f'{TFRECORD_DIR}/test.tfrecord'\n","CSV_PATH = os.path.join(syxlicheng_heartdatabase_path, 'EchoNet-Dynamic', 'FileList.csv')\n","\n","BATCH_SIZE = 4\n","IMG_HEIGHT, IMG_WIDTH, NUM_FRAMES = 112, 112, 28\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"KYAhmND9k6M6"},"outputs":[],"source":["# --- 4. CUSTOM CALLBACKS & METRICS ---\n","class MemoryCallback(tf.keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        try:\n","            mem_info = tf.config.experimental.get_memory_info('GPU:0')\n","            current_mem = mem_info['peak']\n","        except (ValueError, IndexError):\n","            import psutil\n","            process = psutil.Process(os.getpid())\n","            current_mem = process.memory_info().rss\n","        if current_mem > self.max_memory:\n","            self.max_memory = current_mem\n","\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    import tensorflow.keras.backend as K\n","    ss_res = K.sum(K.square(y_true - y_pred))\n","    ss_tot = K.sum(K.square(y_true - K.mean(y_true)))\n","    return K.switch(K.equal(ss_tot, 0), K.zeros_like(ss_tot), 1 - ss_res / (ss_tot + K.epsilon()))"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"FkTZshzPk6QD"},"outputs":[],"source":["# --- 5. DATA PIPELINE ---\n","feature_description = {\n","    'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","    'ef_label': tf.io.FixedLenFeature([], tf.float32),\n","}\n","\n","def create_dataset(tfrecord_path, batch_size, shuffle=True, repeat=False):\n","    ds = tf.data.TFRecordDataset(tfrecord_path, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle: ds = ds.shuffle(buffer_size=1024)\n","    if repeat: ds = ds.repeat()\n","\n","    def _parse_function(proto):\n","        example = tf.io.parse_single_example(proto, feature_description)\n","        clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","        clip = tf.ensure_shape(clip, (NUM_FRAMES, IMG_HEIGHT, IMG_WIDTH))\n","        clip = tf.expand_dims(clip, axis=-1)\n","        label = example['ef_label']\n","        return clip, label\n","\n","    ds = ds.map(_parse_function, num_parallel_calls=tf.data.AUTOTUNE)\n","    ds = ds.batch(batch_size)\n","    ds = ds.prefetch(buffer_size=tf.data.AUTOTUNE)\n","    return ds"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"p3_nK38Qk6SY"},"outputs":[],"source":["# --- 6. MODEL ARCHITECTURE (I3D ALIGNED) ---\n","def conv3d_ln(x, filters, kernel_size, strides=(1, 1, 1), padding='same', name=None):\n","    x = Conv3D(filters, kernel_size, strides=strides, padding=padding, use_bias=False, name=name)(x)\n","    x = LayerNormalization()(x)\n","    return Activation('relu')(x)\n","\n","def build_inception_sub_block(x, filter_config, name_prefix=''):\n","    # Branch 1x1x1\n","    b1 = conv3d_ln(x, filter_config['b0'], (1, 1, 1), name=f'{name_prefix}_b0')\n","    # Branch 1x1x1 -> 3x3x3\n","    b2 = conv3d_ln(x, filter_config['b1_reduce'], (1, 1, 1), name=f'{name_prefix}_b1_reduce')\n","    b2 = conv3d_ln(b2, filter_config['b1'], (3, 3, 3), name=f'{name_prefix}_b1')\n","    # Branch 1x1x1 -> 3x3x3 -> 3x3x3\n","    b3 = conv3d_ln(x, filter_config['b2_reduce'], (1, 1, 1), name=f'{name_prefix}_b2_reduce')\n","    b3 = conv3d_ln(b3, filter_config['b2'], (3, 3, 3), name=f'{name_prefix}_b2a')\n","    b3 = conv3d_ln(b3, filter_config['b2'], (3, 3, 3), name=f'{name_prefix}_b2b')\n","    # Branch Pool -> 1x1x1\n","    b4 = MaxPooling3D((3, 3, 3), strides=(1, 1, 1), padding='same', name=f'{name_prefix}_b3_pool')(x)\n","    b4 = conv3d_ln(b4, filter_config['b3_proj'], (1, 1, 1), name=f'{name_prefix}_b3_proj')\n","    return concatenate([b1, b2, b3, b4], axis=-1)\n","\n","def inception_module_3(input_tensor):\n","    filters_3a = {'b0': 64, 'b1_reduce': 96, 'b1': 128, 'b2_reduce': 16, 'b2': 32, 'b3_proj': 32}\n","    filters_3b = {'b0': 128, 'b1_reduce': 128, 'b1': 192, 'b2_reduce': 32, 'b2': 96, 'b3_proj': 64}\n","    x = build_inception_sub_block(input_tensor, filters_3a, name_prefix='shared_inception_3a')\n","    x = build_inception_sub_block(x, filters_3b, name_prefix='shared_inception_3b')\n","    return x\n","\n","def build_shared_feature_extractor(input_shape):\n","    input_tensor = Input(shape=input_shape)\n","    # --- Stem Block (I3D Aligned) ---\n","    x = Conv3D(64, (7, 7, 7), strides=(2, 2, 2), padding='same', use_bias=False, name='shared_stem_conv1')(input_tensor)\n","    x = LayerNormalization(name='shared_stem_ln1')(x)\n","    x = Activation('relu', name='shared_stem_relu1')(x)\n","    x = MaxPooling3D((1, 3, 3), strides=(1, 2, 2), padding='same', name='shared_stem_pool1')(x)\n","    x = Conv3D(192, (3, 3, 3), strides=(1, 1, 1), padding='same', use_bias=False, name='shared_stem_conv2')(x) #1x1x1\n","    x = LayerNormalization(name='shared_stem_ln2')(x)\n","    x = Activation('relu', name='shared_stem_relu2')(x)\n","    x = MaxPooling3D((1, 3, 3), strides=(1, 2, 2), padding='same', name='shared_stem_pool2')(x)\n","    # --- Inception Block ---\n","    x = inception_module_3(x)\n","    return Model(inputs=input_tensor, outputs=x, name='shared_i3d_backbone')\n","\n","def create_single_input_fusion_model(input_shape=(28, 112, 112, 1), l1_reg=1e-5, l2_reg=1e-4):\n","    reg = l1_l2(l1=l1_reg, l2=l2_reg)\n","    full_frame_input = Input(shape=input_shape, name='full_frame_input')\n","    shared_backbone = build_shared_feature_extractor(input_shape=input_shape)\n","    features = shared_backbone(full_frame_input)\n","    # --- Split Feature Map ---\n","    feature_width = features.shape[3]\n","    spatial_features = Lambda(lambda x: x[:, :, :, :feature_width//2, :], name='spatial_feature_split')(features)\n","    temporal_features = Lambda(lambda x: x[:, :, :, feature_width//2:, :], name='temporal_feature_split')(features)\n","    # --- Dedicated Processing Heads ---\n","    spatial_processed = Conv3D(32, (3, 3, 3), padding='same', activation='relu', kernel_regularizer=reg, name='spatial_head_conv')(spatial_features)\n","    spatial_processed = LayerNormalization(name='spatial_head_norm')(spatial_processed)\n","    spatial_processed = MaxPooling3D((2, 2, 2), name='spatial_head_pool')(spatial_processed)\n","    temporal_processed = Conv3D(32, (3, 3, 3), padding='same', activation='relu', kernel_regularizer=reg, name='temporal_head_conv')(temporal_features)\n","    temporal_processed = LayerNormalization(name='temporal_head_norm')(temporal_processed)\n","    temporal_processed = MaxPooling3D((2, 2, 2), name='temporal_head_pool')(temporal_processed)\n","    # --- Final Classifier ---\n","    spatial_flat = Flatten(name='spatial_flatten')(spatial_processed)\n","    temporal_flat = Flatten(name='temporal_flatten')(temporal_processed)\n","    merged = concatenate([spatial_flat, temporal_flat], name='final_concatenate')\n","    merged = Dense(1024, activation='relu', kernel_regularizer=reg, name='final_dense_1')(merged)\n","    merged = Dropout(0.50, name='final_dropout')(merged)\n","    final_output = Dense(1, activation='linear', dtype='float32', name=\"ef_output\")(merged)\n","    return Model(inputs=full_frame_input, outputs=final_output, name='single_input_fusion_model')"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":944},"id":"9J-dmcXtk8C6","executionInfo":{"status":"ok","timestamp":1761331011858,"user_tz":420,"elapsed":4716,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"29c57dab-956b-44cc-d0b1-27c73bbe87d3"},"outputs":[{"output_type":"stream","name":"stdout","text":["All outputs for this run will be saved in: /content/drive/My Drive/LVEF Prediction Models/Fusion Models/Single Input Fusion Models/LVEF Fusion SI-7\n","Steps: 1866 per epoch, 322 for validation, 320 for test\n"]},{"output_type":"display_data","data":{"text/plain":["\u001b[1mModel: \"single_input_fusion_model\"\u001b[0m\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"single_input_fusion_model\"</span>\n","</pre>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["┏━━━━━