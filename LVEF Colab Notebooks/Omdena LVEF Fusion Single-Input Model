ting Best Model ---\")\n","    val_results = best_model.evaluate(val_ds, steps=validation_steps, return_dict=True, verbose=0)\n","    test_results = best_model.evaluate(test_ds, steps=test_steps, return_dict=True, verbose=0)\n","\n","    print(\"--- Generating Predictions ---\")\n","    # Note: For single-input model, the data format from ds.map is just (x, y)\n","    y_val_true = np.concatenate([y.numpy() for y in val_ds.map(lambda x, y: y)])\n","    y_val_pred = best_model.predict(val_ds, steps=validation_steps, verbose=0)\n","    val_r2 = sk_r2_score(y_val_true, y_val_pred)\n","    y_test_true = np.concatenate([y.numpy() for y in test_ds.map(lambda x, y: y)])\n","    y_test_pred = best_model.predict(test_ds, steps=test_steps, verbose=0)\n","    test_r2 = sk_r2_score(y_test_true, y_test_pred)\n","\n","    total_duration_seconds = end_time - start_time\n","    num_epochs_run = len(history.history['loss'])\n","    avg_time_per_epoch = total_duration_seconds / num_epochs_run if num_epochs_run > 0 else 0\n","    readable_total_time = str(timedelta(seconds=int(total_duration_seconds)))\n","    max_ram_gb = memory_callback.max_memory / (1024**3)\n","\n","    final_model_path = os.path.join(experiment_dir, \"final_model.keras\")\n","    shutil.copy(best_model_path, final_model_path)\n","\n","    plot_path = os.path.join(experiment_dir, \"performance_analysis_plot.png\")\n","    fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","    y_true_flat, y_pred_flat = y_test_true.flatten(), y_test_pred.flatten()\n","    axes[0].scatter(y_true_flat, y_pred_flat, alpha=0.5)\n","    axes[0].plot([y_true_flat.min(), y_true_flat.max()], [y_true_flat.min(), y_true_flat.max()], '--', lw=2, color='red')\n","    axes[0].set_xlabel(\"Ground Truth EF (%)\"), axes[0].set_ylabel(\"Predicted EF (%)\"), axes[0].set_title(\"Prediction vs. Ground Truth\")\n","    axes[0].grid(True)\n","    mean = np.mean([y_true_flat, y_pred_flat], axis=0)\n","    diff = y_true_flat - y_pred_flat\n","    md, sd =