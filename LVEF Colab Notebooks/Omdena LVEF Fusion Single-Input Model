\n","test_ds = create_dataset(TEST_TFRECORD_PATH, global_batch_size, shuffle=False, repeat=False)\n","\n","# Calculate steps\n","steps_per_epoch = len(df[df[\"Split\"] == \"TRAIN\"]) // global_batch_size\n","validation_steps = -(-len(df[df[\"Split\"] == \"VAL\"]) // global_batch_size)\n","test_steps = -(-len(df[df[\"Split\"] == \"TEST\"]) // global_batch_size)\n","print(f\"Steps: {steps_per_epoch} per epoch, {validation_steps} for validation, {test_steps} for test\")\n","\n","# Learning Rate Schedule\n","def step_decay(epoch):\n","    drop = 0.5\n","    epochs_drop = 10.0\n","    lr = INITIAL_LR * math.pow(drop, math.floor((epoch)/epochs_drop))\n","    return lr\n","\n","# --- Build and Compile Model ---\n","with strategy.scope():\n","    model = create_single_input_fusion_model(l1_reg=L1_REG, l2_reg=L2_REG)\n","    optimizer = tf.keras.optimizers.Adam(clipnorm=1.0)\n","    model.compile(\n","        loss=tf.keras.losses.MeanSquaredError(),\n","        optimizer=optimizer,\n","        metrics=[\n","            tf.keras.metrics.RootMeanSquaredError(name=\"rmse\"),\n","            tf.keras.metrics.MeanAbsoluteError(name=\"mae\"),\n","            r2_score\n","        ]\n","    )\n","model.summary()\n","\n","# --- Define Callbacks ---\n","memory_callback = MemoryCallback()\n","callbacks = [\n","    ModelCheckpoint(filepath=os.path.join(experiment_dir, \"best_model.keras\"), monitor=\"val_rmse\", save_best_only=True, mode='min', verbose=1),\n","    CSVLogger(os.path.join(experiment_dir, \"training_log.csv\")),\n","    EarlyStopping(monitor=\"val_loss\", patience=PATIENCE, min_delta=1e-3, restore_best_weights=True, verbose=1),\n","    TensorBoard(log_dir=os.path.join(experiment_dir, \"logs\")),\n","    LearningRateScheduler(step_decay, verbose=1),\n","    memory_callback\n","]"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"IFgTn6nFk8E9","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1761332039202,"user_tz":420,"e