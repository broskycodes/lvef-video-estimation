en":false},"id":"qsQV5KxjaYXw"},"cell_type":"code","source":["# New data stream using TFRecord cache\n","# Define the feature description for parsing the TFRecords\n","feature_description = {\n","    'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","    'ef_label': tf.io.FixedLenFeature([], tf.float32),\n","}\n","\n","def _parse_and_split_stream(proto):\n","    \"\"\"Parses a TFRecord, splits the clip into spatial and temporal streams.\"\"\"\n","    # 1. Parse the raw data\n","    example = tf.io.parse_single_example(proto, feature_description)\n","    clip_raw = example['clip_raw']\n","    label = example['ef_label']\n","\n","    # 2. Decode the serialized tensor\n","    clip = tf.io.parse_tensor(clip_raw, out_type=tf.float32)\n","    clip = tf.ensure_shape(clip, (NUM_FRAMES, IMG_HEIGHT, IMG_WIDTH))\n","\n","    # 3. Add the channel dimension\n","    clip = tf.expand_dims(clip, axis=-1) # Shape: (28, 112, 112, 1)\n","\n","    # 4. Create the SPATIAL stream (left half of the image)\n","    spatial_stream = clip[:, :, :IMG_WIDTH // 2, :]\n","    spatial_stream = tf.ensure_shape(spatial_stream, (28, 112, 56, 1))\n","\n","    # 5. Create the TEMPORAL stream (frame differences of the right half)\n","    temporal_half = clip[:, :, IMG_WIDTH // 2:, :]\n","    temporal_stream = temporal_half[1:, :, :, :] - temporal_half[:-1, :, :, :]\n","\n","    # Add proper normalization\n","    temporal_mean = tf.reduce_mean(temporal_stream, axis=[1, 2, 3], keepdims=True)\n","    temporal_std = tf.math.reduce_std(temporal_stream, axis=[1, 2, 3], keepdims=True)\n","    temporal_std = tf.maximum(temporal_std, 1e-6)  # Prevent division by zero\n","    temporal_stream = (temporal_stream - temporal_mean) / temporal_std\n","\n","    temporal_stream = tf.ensure_shape(temporal_stream, (27, 112, 56, 1))\n","\n","    # Return in the format Keras expects for a multi-input model\n","    return (spatial_stream, temporal_stream), label"],"execution_count":null,"outputs":[]},{"metadata":{"_uuid":"21a319c6-86cc-43ce-8567-afca8a52bcde","_cell_guid":"f832205f-2ec7-4db0-8d3b-b0fce8aae993","trusted":true,"jupyter":{"outputs_hidden":false},"id":"hRmAPuwaaYXw"},"cell_type":"code","source":["def create_dataset(tfrecord_path, batch_size, shuffle=True, repeat=False):\n","    \"\"\"Creates a batched and prefetched TFRecord dataset from a file path.\"\"\"\n","    ds = tf.data.TFRecordDataset(tfrecord_path, num_parallel_reads=tf.data.AUTOTUNE)\n","\n","    if shuffle:\n","        ds = ds.shuffle(buffer_size=1024)\n","\n","    # Only repeats dataset if repeat=True\n","    if repeat:\n","        ds = ds.repeat()\n","\n","    ds = ds.map(_parse_and_split_stream, num_parallel_calls=tf.data.AUTOTUNE)\n","    ds = ds.batch(batch_size)\n","    ds = ds.prefetch(buffer_size=tf.data.AUTOTUNE)\n","\n","    return ds"],"execution_count":null,"outputs":[]},{"metadata":{"_uuid":"d599ac77-5b39-4e53-8a44-11c25994cdf7","_cell_guid":"2327203b-b782-40be-9182-b259e9bc5def","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"id":"68q6zokOaYXw"},"cell_type":"markdown","source":["### Cutmix"]},{"metadata":{"_uuid":"856d294a-a10f-4ac6-8da3-43fafa742daf","_cell_guid":"3d27abdf-d1b1-43ea-915a-e662c63150a0","trusted":true,"execution":{"execution_failed":"2025-07-22T20:46:41.669Z"},"jupyter":{"outputs_hidden":false},"id":"21jO_LSWaYXw"},"cell_type":"code","source":["# Replaced np operations with tf operations\n","class CutMixLayer(tf.keras.layers.Layer):\n","    def __init__(self, alpha=1.0):\n","        super(CutMixLayer, self).__init__()\n","        self.alpha = alpha\n","\n","    def call(self, inputs, labels):\n","        batch_size = tf.shape(inputs)[0]\n","        indices = tf.random.shuffle(tf.range(batch_size))\n","        shuffled_inputs = tf.gather(inputs, indices)\n","        shuffled_labels = tf.gather(labels, indices)\n","\n","        lam = tf.random.uniform([], 0.0, 1.0)\n","\n","        h, w, c = tf.shape(inputs)[1], tf.shape(inputs)[2], tf.shape(inputs)[3]\n","        cut_w = tf.cast(tf.cast(w, tf.float32) * tf.sqrt(1 - lam), tf.int32)\n","        cut_h = tf.cast(tf.cast(h, tf.float32) * tf.sqrt(1 - lam), tf.int32)\n","        cut_x = tf.random.uniform([], 0, w - cut_w + 1, dtype=tf.int32)\n","        cut_y = tf.random.uniform([], 0, h - cut_h + 1, dtype=tf.int32)\n","\n","        mask = tf.ones((batch_size, cut_h, cut_w, c))\n","        mask = tf.pad(mask, [[0, 0], [cut_y, h - cut_h - cut_y], [cut_x, w - cut_w - cut_x], [0, 0]])\n","\n","        inputs = inputs * (1 - mask) + shuffled_inputs * mask\n","        labels = tf.concat([tf.expand_dims(labels, -1), tf.expand_dims(shuffled_labels, -1)], axis=-1)\n","        labels = tf.cast(labels, tf.float32) * tf.constant([1 - lam, lam])\n","\n","        return inputs, labels"],"execution_count":null,"outputs":[]},{"metadata":{"_uuid":"92775fa2-4110-46a0-81ae-e6108bed1b38","_cell_guid":"909af422-42f5-4dcd-b5b6-0606b2f5d392","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"id":"B4LomB3XaYXw"},"cell_type":"markdown","source":["## Model"]},{"metadata":{"_uuid":"5d82f97c-f1bc-4e17-a833-9f9f466721c9","_cell_guid":"9fd34453-f59e-4fe3-823e-d5cd62a54556","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"id":"XBGsM4pvaYXw"},"cell_type":"markdown","source":["## Callbacks"]},{"metadata":{"_uuid":"f5b6f3d3-dd47-4027-a8cd-8fdefce4831a","_cell_guid":"9a6db5ef-8324-4e05-b6f9-3be88386d128","trusted":true,"execution":{"execution_failed":"2025-07-22T20:46:41.669Z"},"jupyter":{"outputs_hidden":false},"id":"eqICXQGFaYXw"},"cell_type":"code","source":["# Preprocessing for disk-cache\n","from tensorflow.keras.callbacks import LearningRateScheduler, Callback\n","\n","class DebugLogger(tf.keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        print(\"[{}] training started\".format(datetime.now()), flush=True)\n","\n","    def on_epoch_begin(self, epoch, logs=None):\n","        print(\"[{}] epoch {} start\".format(datetime.now(), epoch + 1)