_output)\n","\n","    return spatial_model\n","\n","\n","def create_temporal_model(input_shape=(27, 112, 56, 1)):\n","    temporal_input = Input(shape=input_shape, name='temporal_input')\n","\n","    # Using l1_l2 regularizer\n","    x = Conv3D(32, kernel_size=(3, 3, 3), activation='relu', padding='same',\n","               kernel_regularizer=l1_l2(l1=1e-5, l2=1e-4))(temporal_input)\n","\n","    # Switched to BatchNormalization\n","    x = BatchNormalization()(x)\n","\n","    x = MaxPooling3D(pool_size=(2, 2, 2))(x)\n","    x = Flatten()(x)\n","\n","    # Using l1_l2 regularizer\n","    x = Dense(64, activation='relu',\n","              kernel_regularizer=l1_l2(l1=1e-5, l2=1e-4))(x)\n","\n","    x = Dropout(0.05)(x)\n","    temporal_output = Dense(1, activation='linear')(x)\n","    temporal_model = Model(inputs=temporal_input, outputs=temporal_output)\n","\n","    return temporal_model\n","\n","\n","def create_two_stream_model(spatial_model, temporal_model):\n","    spatial_output = spatial_model.output\n","    temporal_output = temporal_model.output\n","\n","    merged = concatenate([spatial_output, temporal_output])\n","\n","    # Using l1_l2 regularizer\n","    merged = Dense(1024, activation='relu',\n","                   kernel_regularizer=l1_l2(l1=1e-5, l2=1e-4))(merged)\n","\n","    merged = Dropout(0.05)(merged)\n","    merged_output = Dense(1, activation='linear', dtype='float32', name=\"ef_output\")(merged)\n","\n","    two_stream_model = Model(inputs=[spatial_model.input, temporal_model.input], outputs=merged_output)\n","\n","    return two_stream_model"],"execution_count":null,"outputs":[]},{"metadata":{"_uuid":"cecc2fd2-1728-40f3-b052-0f3a75e1257c","_cell_guid":"2e8ea2aa-fab3-4d9f-9dae-ff9a3e594c38","trusted":true,"execution":{"iopub.status.busy":"2025-07-21T06:30:22.807108Z","iopub.execute_input":"2025-07-21T06:30:22.807511Z","iopub.status.idle":"2025-07-21T06:30:22.826629Z","shell.execute_reply.started":"2025-07-21T06:30:22.80748Z","shell.execute_repl