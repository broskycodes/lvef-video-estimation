━━━━━━━━━━━\u001b[0m\u001b[37m━\u001b[0m \u001b[1m0s\u001b[0m 33ms/step - loss: 25.5279 - mae: 3.8526 - r2_score: -31.3447 - rmse: 4.8853\n","Epoch 35: val_rmse did not improve from 7.65161\n","\u001b[1m466/466\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m16s\u001b[0m 35ms/step - loss: 25.5250 - mae: 3.8523 - r2_score: -31.3447 - rmse: 4.8850 - val_loss: 64.6278 - val_mae: 5.9018 - val_r2_score: -29.4313 - val_rmse: 7.9354 - learning_rate: 1.2500e-04\n","Epoch 35: early stopping\n","Restoring model weights from the end of the best epoch: 15.\n","\n","--- Training Finished ---\n","\n","--- Evaluating Best Model ---\n","SUCCESS: Generated 'evaluation_metrics.txt'.\n","SUCCESS: Generated 'performance_analysis_plot.png'.\n"]}],"source":["# IMPORTANT: SOME KAGGLE DATA SOURCES ARE PRIVATE\n","# RUN THIS CELL IN ORDER TO IMPORT YOUR KAGGLE DATA SOURCES.\n","import kagglehub\n","\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","# IMPORTANT: RUN THIS CELL IN ORDER TO IMPORT YOUR KAGGLE DATA SOURCES,\n","# THEN FEEL FREE TO DELETE THIS CELL.\n","# NOTE: THIS NOTEBOOK ENVIRONMENT DIFFERS FROM KAGGLE'S PYTHON\n","# ENVIRONMENT SO THERE MAY BE MISSING LIBRARIES USED BY YOUR\n","# NOTEBOOK.\n","\n","syxlicheng_heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","shravansaranyan_lvef_two_stream_tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-two-stream-tfrecord-files')\n","\n","print('Data source import complete.')\n","\n","# --- Install Dependencies ---\n","!pip install scikit-video -q\n","!pip install imageio -q\n","\n","# --- Import Libraries ---\n","from tensorflow.keras import mixed_precision\n","mixed_precision.set_global_policy('mixed_float16')\n","\n","import tensorflow as tf\n","from tensorflow import keras\n","import matplotlib.pyplot as plt\n","import pandas as pd\n","import numpy as np\n","import os\n","import shutil\n","import math\n","from datetime import datetime, timedelta\n","import time\n","import psutil\n","\n","from tensorflow.keras.models import Model, load_model\n","from tensorflow.keras.layers import (Input, Conv3D, MaxPooling3D, Dense, concatenate, Dropout,\n","                                     GlobalAveragePooling3D, ZeroPadding3D, LayerNormalization, ReLU)\n","from tensorflow.keras.regularizers import l1_l2\n","from tensorflow.keras.callbacks import ModelCheckpoint, CSVLogger, EarlyStopping, LearningRateScheduler\n","from sklearn.metrics import r2_score as sk_r2_score\n","\n","# --- Configuration and Data Loading ---\n","csv_path = os.path.join(syxlicheng_heartdatabase_path, 'EchoNet-Dynamic/FileList.csv')\n","df = pd.read_csv(csv_path)\n","print(f\"Total videos for training: {len(df)}\")\n","\n","strategy = tf.distribute.get_strategy()\n","\n","# --- Hyperparameters and Constants ---\n","# Architecture & Data\n","FRAMES = 28\n","IMG_HEIGHT = 112\n","IMG_WIDTH = 112\n","L1_REG = 1e-5\n","L2_REG = 1e-4\n","DROPOUT_RATE = 0.5\n","\n","# Training\n","BATCH_SIZE = 16\n","INITIAL_LR = 1e-3\n","EPOCHS = 50 # A high number, but EarlyStopping will find the best epoch.\n","PATIENCE = 20\n","\n","# Paths\n","TFRECORD_DIR = shravansaranyan_lvef_two_stream_tfrecord_files_path\n","TRAIN_TFRECORD_PATH = os.path.join(TFRECORD_DIR, 'train.tfrecord')\n","VAL_TFRECORD_PATH = os.path.join(TFRECORD_DIR, 'val.tfrecord')\n","TEST_TFRECORD_PATH = os.path.join(TFRECORD_DIR, 'test.tfrecord')\n","\n","# --- Callbacks and Custom Metrics ---\n","class MemoryCallback(tf.keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None): self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        import psutil\n","        process = psutil.Process(os.getpid())\n","        current_mem = process.memory_info().rss\n","        if current_mem > self.max_memory: self.max_memory = current_mem\n","\n","def lr_step_decay(epoch, lr):\n","    \"\"\"Halves the learning rate every 10 epochs.\"\"\"\n","    drop_rate = 0.5\n","    epochs_drop = 10.0\n","    new_lr = INITIAL_LR * (drop_rate ** (epoch // epochs_drop))\n","    return new_lr\n","\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    import tensorflow.keras.backend as K\n","    ss_res = K.sum(K.square(y_true - y_pred))\n","    ss_tot = K.sum(K.square(y_true - K.mean(y_true)))\n","    return K.switch(K.equal(ss_tot, 0), K.zeros_like(ss_tot), 1 - ss_res / (ss_tot + K.epsilon()))\n","\n","# --- Data Pipeline ---\n","feature_description = {\n","    'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","    'ef_label': tf.io.FixedLenFeature([], tf.float32),\n","}\n","\n","def _split_streams_from_clip(clip, label):\n","    spatial_stream = clip[:, :, :IMG_WIDTH // 2, :]\n","    spatial_stream = tf.ensure_shape(spatial_stream, (FRAMES, IMG_HEIGHT, IMG_WIDTH // 2, 1))\n","\n","    temporal_half = clip[:, :, IMG_WIDTH // 2:, :]\n","    temporal_stream = temporal_half[1:, :, :, :] - temporal_half[:-1, :, :, :]\n","    temporal_mean = tf.reduce_mean(temporal_stream, axis=[1, 2, 3], keepdims=True)\n","    temporal_std = tf.math.reduce_std(temporal_stream, axis=[1, 2, 3], keepdims=True)\n","    temporal_stream = (temporal_stream - temporal_mean) / tf.maximum(temporal_std, 1e-6)\n","    temporal_stream = tf.ensure_shape(temporal_stream, (FRAMES - 1, IMG_HEIGHT, IMG_WIDTH // 2, 1))\n","\n","    return (spatial_stream, temporal_stream), label\n","\n","def create_dataset(tfrecord_path, batch_size, shuffle=True, repeat=False):\n","    ds = tf.data.TFRecordDataset(tfrecord_path, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle: ds = ds.shuffle(buffer_size=1024)\n","    if repeat: ds = ds.repeat()\n","    def _parse_function(proto):\n","        example = tf.io.parse_single_example(proto, feature_description)\n","        clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","        clip = tf.ensure_shape(clip, (FRAMES, IMG_HEIGHT, IMG_WIDTH))\n","        clip = tf.expand_dims(clip, axis=-1)\n","        return clip, example['ef_label']\n","    ds = ds.map(_parse_function, num_parallel_calls=tf.data.AUTOTUNE)\n","    ds = ds.map(_split_streams_from_clip, num_parallel_calls=tf.data.AUTOTUNE)\n","    ds = ds.batch(batch_size).prefetch(buffer_size=tf.data.AUTOTUNE)\n","    return ds\n","\n","# --- 🧱 I3D-Aligned Model Architecture 🧱 ---\n","def conv3d_ln(x, filters, kernel_size, strides=(1, 1, 1), padding='same', use_bias=False, name=None):\n","    x = Conv3D(filters, kernel_size, strides=strides, padding=padding, use_bias=use_bias, name=name, kernel_regularizer=l1_l2(l1=L1_REG, l2=L2_REG))(x)\n","    x = LayerNormalization()(x)\n","    return ReLU()(x)\n","\n","def i3d_inception_module(x, f1, f2_reduce, f2_out, f3_reduce, f3_out, f4_out, stream_prefix, name=None):\n","    \"\"\"Exact Inception module structure from the I3D reference code.\"\"\"\n","    full_name = f'{stream_prefix}_{name}'\n","    # Branch 1: 1x1x1 Conv\n","    branch1x1 = conv3d_ln(x, f1, (1, 1, 1), name=f'{full_name}_b1')\n","    # Branch 2: 1x1x1 -> 3x3x3 Conv\n","    branch3x3 = conv3d_ln(x, f2_reduce, (1, 1, 1), name=f'{full_name}_b2_reduce')\n","    branch3x3 = conv3d_ln(branch3x3, f2_out, (3, 3, 3), name=f'{full_name}_b2_out')\n","    # Branch 3: 1x1x1 -> 3x3x3 -> 3x3x3 Conv\n","    branch3x3dbl = conv3d_ln(x, f3_reduce, (1, 1, 1), name=f'{full_name}_b3_reduce')\n","    branch3x3dbl = conv3d_ln(branch3x3dbl, f3_out, (3, 3, 3), name=f'{full_name}_b3_out1')\n","    branch3x3dbl = conv3d_ln(branch3x3dbl, f3_out, (3, 3, 3), name=f'{full_name}_b3_out2')\n","    # Branch 4: MaxPooling -> 1x1x1 Conv\n","    branch_pool = MaxPooling3D((3, 3, 3), strides=(1, 1, 1), padding='same', name=f'{full_name}_b4_pool')(x)\n","    branch_pool = conv3d_ln(branch_pool, f4_out, (1, 1, 1), name=f'{full_name}_b4_out')\n","    return concatenate([branch1x1, branch3x3, branch3x3dbl, branch_pool], axis=-1, name=f'{full_name}_concat') # Concatinate channel-wise (axis = -1)\n","\n","def build_i3d_aligned_backbone(input_tensor, stream_prefix):\n","    \"\"\"Builds the feature extraction part of a stream, matching the I3D architecture.\"\"\"\n","    # --- STEM (matches I3D exactly) ---\n","    x = conv3d_ln(input_tensor, 64, (7, 7, 7), strides=(2, 2, 2), name=f'{stream_prefix}_conv1')\n","    x = MaxPooling3D((1, 3, 3), strides=(1, 2, 2), padding='same', name=f'{stream_prefix}_pool1')(x)\n","    # --- Conv2 (as per special instruction) ---\n","    x = conv3d_ln(x, 192, (3, 3, 3), name=f'{stream_prefix}_conv2') # 3x3x3 modification\n","    x = MaxPooling3D((1, 3, 3), strides=(1, 2, 2), padding='same', name=f'{stream_prefix}_pool2')(x)\n","    # --- INCEPTION MODULE 3 (matches I3D exactly) ---\n","    x = i3d_inception_module(x, 64, 96, 128, 16, 32, 32, stream_prefix, name='inception_3a')\n","    x = i3d_inception_module(x, 128, 128, 192, 32, 96, 64, stream_prefix, name='inception_3b')\n","    return x\n","\n","def build_early_fusion_model():\n","    \"\"\"Builds the complete model with two I3D-aligned backbones and a shared head.\"\"\"\n","    spatial_input = Input(shape=(28, 112, 56, 1), name='spatial_input')\n","    temporal_input = Input(shape=(27, 112, 56, 1), name='temporal_input')\n","    padded_temporal_input = ZeroPadding3D(padding=((1, 0), (0, 0), (0, 0)), name='temporal_padding')(temporal_input)\n","\n","    spatial_backbone = build_i3d_aligned_backbone(spatial_input, 'spatial')\n","    temporal_backbone = build_i3d_aligned_backbone(padded_temporal_input, 'temporal')\n","\n","    fused_features = concatenate([spatial_backbone, temporal_backbone], axis=-1, name='channel_fusion')\n","\n","    # --- NEW, More Powerful Shared Regression Head ---\n","    x = GlobalAveragePooling3D(name='fused_head_gap')(fused_features)\n","\n","    # Add a dense layer to learn complex feature interactions\n","    reg = l1_l2(l1=L1_REG, l2=L2_REG)\n","    x = Dense(1024, activation='relu', kernel_regularizer=reg, name='fused_head_dense_1')(x)\n","\n","    x = Dropout(DROPOUT_RATE, name='fused_head_dropout')(x)\n","\n","    # Final output layer for regression\n","    final_output = Dense(1, activation='linear', dtype='float32', name=\"ef_output\")(x)\n","\n","    model = Model(inputs=[spatial_input, temporal_input], outputs=final_output, name='i3d_aligned_fusion_model')\n","    return model\n","\n","# --- Training Setup and Execution ---\n","run_name = \"LVEF Fusion NC-6\"\n","save_path = \"/content/drive/My Drive/LVEF Prediction Models/Fusion Models/New Fusion Models\"\n","experiment_dir = os.path.join(save_path, run_name)\n","os.makedirs(experiment_dir, exist_ok=True)\n","print(f\"All outputs for this run will be saved in: {experiment_dir}\")\n","\n","global_batch_size = BATCH_SIZE * strategy.num_replicas_in_sync\n","train_ds = create_dataset(TRAIN_TFRECORD_PATH, global_batch_size, shuffle=True, repeat=True)\n","val_ds = create_dataset(VAL_TFRECORD_PATH, global_batch_size, shuffle=False, repeat=True)\n","\n","num_train_samples = len(df[df[\"Split\"] == \"TRAIN\"])\n","num_val_samples = len(df[df[\"Split\"] == \"VAL\"])\n","steps_per_epoch = num_train_samples // global_batch_size\n","validation_steps = num_val_samples // global_batch_size\n","\n","with strategy.scope():\n","    model = build_early_fusion_model()\n","    optimizer = tf.keras.optimizers.Adam(learning_rate=INITIAL_LR)\n","    model.compile(loss='mse', optimizer=optimizer,\n","                  metrics=[tf.keras.metrics.RootMeanSquaredError(name=\"rmse\"),\n","                           tf.keras.metrics.MeanAbsoluteError(name=\"mae\"), r2_score])\n","model.summary()\n","\n","memory_callback = MemoryCallback()\n","callbacks = [\n","    ModelCheckpoint(filepath=os.path.join(experiment_dir, \"best_model.keras\"),\n","                    monitor=\"val_rmse\", save_best_only=True, mode='min', verbose=1),\n","    CSVLogger(os.path.join(experiment_dir, \"training_log.csv\")),\n","    EarlyStopping(monitor=\"val_rmse\", patience=PATIENCE, restore_best_weights=True, verbose=1),\n","    LearningRateScheduler(lr_step_decay, verbose=1),\n","    memory_callback\n","]\n","\n","# --- 🏃‍♂️ Run Training 🏃‍♂️ ---\n","print(f\"\\n--- Starting Training for {run_name} ---\")\n","start_time = time.time()\n","history = model.fit(train_ds, epochs=EPOCHS, steps_per_epoch=steps_per_epoch,\n","                    validation_data=val_ds, validation_steps=validation_steps,\n","                    callbacks=callbacks, verbose=1)\n","end_time = time.time()\n","print(\"\\n--- Training Finished ---\")\n","\n","# --- 📊 Evaluation and Reporting 📊 ---\n","try:\n","    best_model_path = os.path.join(experiment_dir, \"best_model.keras\")\n","    best_model = load_model(best_model_path, custom_objects={'r2_score': r2_score})\n","\n","    val_ds_eval = create_dataset(VAL_TFRECORD_PATH, global_batch_size, shuffle=False, repeat=False)\n","    test_ds_eval = create_dataset(TEST_TFRECORD_PATH, global_batch_size, shuffle=False, repeat=False)\n","\n","    # Recalculate steps for validation and test sets using ceiling division\n","    num_val_samples = len(df[df[\"Split\"] == \"VAL\"])\n","    validation_steps = -(-num_val_samples // global_batch_size)\n","\n","    num_test_samples = len(df[df[\"Split\"] == \"TEST\"])\n","    test_steps = -(-num_test_samples // global_batch_size) # Ceiling division\n","\n","    print(\"\\n--- Evaluating Best Model ---\")\n","    test_results = best_model.evaluate(test_ds_eval, steps=test_steps, return_dict=True, verbose=0)\n","    val_results = best_model.evaluate(val_ds_eval, steps=validation_steps, return_dict=True, verbose=0)\n","\n","    y_val_true = np.concatenate([y.numpy() for x, y in val_ds_eval])\n","    y_val_pred = best_model.predict(val_ds_eval, steps=validation_steps, verbose=0)\n","    val_r2 = sk_r2_score(y_val_true, y_val_pred)\n","\n","    y_test_true = np.concatenate([y.numpy() for x, y in test_ds_eval])\n","    y_test_pred = best_model.predict(test_ds_eval, steps=test_steps, verbose=0)\n","    test_r2 = sk_r2_score(y_test_true, y_test_pred)\n","\n","    total_duration_seconds = end_time - start_time\n","    num_epochs_run = len(history.history['loss'])\n","    avg_time_per_epoch = total_duration_seconds / num_epochs_run if num_epochs_run > 0 else 0\n","    readable_total_time = str(timedelta(seconds=int(total_duration_seconds)))\n","    max_ram_gb = memory_callback.max_memory / (1024**3)\n","\n","    shutil.copy(best_model_path, os.path.join(experiment_dir, \"final_model.keras\"))\n","    metrics_path = os.path.join(experiment_dir, \"evaluation_metrics.txt\")\n","    with open(metrics_path, 'w') as f:\n","        f.write(f\"Evaluation Metrics for Run: {run_name}\\n\" + \"=\"*40 + \"\\n\\n\")\n","        f.write(f\"Total Training Time: {readable_total_time}\\n\")\n","        f.write(f\"Average Time per Epoch: {avg_time_per_epoch:.2f} seconds\\n\")\n","        f.write(f\"Maximum RAM Used: {max_ram_gb:.2f} GB\\n\\n\")\n","        f.write(\"Validation Set Metrics:\\n\" + f\"  - RMSE: {val_results['rmse']:.4f}\\n\" + f\"  - MAE: {val_results['mae']:.4f}\\n\" + f\"  - Sklearn R^2: {val_r2:.4f}\\n\\n\")\n","        f.write(\"Test Set Metrics:\\n\" + f\"  - RMSE: {test_results['rmse']:.4f}\\n\" + f\"  - MAE: {test_results['mae']:.4f}\\n\" + f\"  - Sklearn R^2: {test_r2:.4f}\\n\")\n","    print(f\"SUCCESS: Generated 'evaluation_metrics.txt'.\")\n","\n","    plot_path = os.path.join(experiment_dir, \"performance_analysis_plot.png\")\n","    fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","    y_true_flat, y_pred_flat = y_test_true.flatten(), y_test_pred.flatten()\n","    axes[0].scatter(y_true_flat, y_pred_flat, alpha=0.5); axes[0].plot([y_true_flat.min(), y_true_flat.max()], [y_true_flat.min(), y_true_flat.max()], '--', lw=2, color='red'); axes[0].set_xlabel(\"Ground Truth EF (%)\"); axes[0].set_ylabel(\"Predicted EF (%)\"); axes[0].set_title(\"Prediction vs. Ground Truth\"); axes[0].grid(True)\n","    mean = np.mean([y_true_flat, y_pred_flat], axis=0); diff = y_true_flat - y_pred_flat; md, sd = np.mean(diff), np.std(diff)\n","    axes[1].scatter(mean, diff, alpha=0.5); axes[1].axhline(md, color='gray', linestyle='--'); axes[1].axhline(md + 1.96 * sd, color='red', linestyle='--'); axes[1].axhline(md - 1.96 * sd, color='red', linestyle='--'); axes[1].set_xlabel(\"Average of GT and Prediction\"); axes[1].set_ylabel(\"Difference (GT - Prediction)\"); axes[1].set_title(\"Bland-Altman Plot\"); axes[1].grid(True)\n","    plt.suptitle(f\"Performance Analysis for {run_name} (Test Set)\"); plt.tight_layout(rect=[0, 0.03, 1, 0.95]); fig.savefig(plot_path); plt.close(fig)\n","    print(f\"SUCCESS: Generated 'performance_analysis_plot.png'.\")\n","\n","except Exception as e:\n","    print(f\"\\nAn error occurred during post-training evaluation: {e}\")\n","\n","from google.colab import runtime\n","runtime.unassign()"]}]}