he learning rate every 10 epochs.\n","    \"\"\"\n","    initial_lr = 1e-3   # The starting learning rate\n","    drop_rate = 0.5     # The factor to multiply by\n","    epochs_drop = 10.0  # How often to apply the decay\n","\n","    new_lr = initial_lr * (drop_rate ** (epoch // epochs_drop))\n","    return new_lr\n","\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    ss_res =  keras.backend.sum(keras.backend.square(y_true - y_pred))\n","    ss_tot = keras.backend.sum(keras.backend.square(y_true - keras.backend.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + keras.backend.epsilon())\n","\n","class MemoryCallback(keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        self.max_memory = 0\n","\n","    def on_epoch_end(self, epoch, logs=None):\n","        mem_info = psutil.Process(os.getpid()).memory_info()\n","        self.max_memory = max(self.max_memory, mem_info.rss)\n","\n","    def on_train_end(self, logs=None):\n","        # This runs only when training completes\n","        max_ram_gb = self.max_memory / (1024**3)\n","        # Save the result to a persistent file\n","        with open(os.path.join(experiment_dir, 'max_ram_usage.txt'), 'w') as f:\n","            f.write(str(max_ram_gb))\n","\n","memory_callback = MemoryCallback()\n","model_path = os.path.join(experiment_dir, \"best_model.keras\")\n","log_file = os.path.join(experiment_dir, \"training_log.csv\")\n","\n","callbacks = [\n","    keras.callbacks.ModelCheckpoint(\n","        filepath=model_path,\n","        monitor=\"val_rmse\", save_best_only=True, mode='min', verbose=1\n","    ),\n","    keras.callbacks.CSVLogger(log_file, append=True),\n","    keras.callbacks.EarlyStopping(\n","        monitor=\"val_rmse\", patience=20, restore_best_weights=True, verbose=1\n","    ),\n","    keras.callbacks.LearningRateScheduler(lr_step_decay, verbose=1),\n","    memory_callback\n","]\n","\n","# --- 2. Check for Existing Progress and Load or Build Model ---\n","try:\n","    # Try to read the last epoch from the log file\n","    log_data = pd.read_csv(log_file)\n","    resume_epoch = log_data['epoch'].iloc[-1] + 1\n","    print(f\"Log file found. Resuming training from epoch {resume_epoch}.\")\n","\n","    # Load the previously saved model\n","    model = keras.models.load_model(model_path, custom_objects={\"r2_score\": r2_score})\n","\n","except (FileNotFoundError, IndexError):\n","    # If no log file or it's empty, start a new run\n","    resume_epoch = 0\n","    print(\"No log file or model found. Starting a new training run from epoch 0.\")\n","\n","    # Build and compile a brand new model\n","    model = build_i2d_rnn_model()\n","    model.compile(\n","        optimizer=keras.optimizers.Adam(learning_rate=1e-3),\n","        loss='mse',\n","        metrics=[tf.keras.metrics.RootMeanSquaredError(name='rmse'), tf.keras.metrics.MeanAbsoluteError(name='mae'), r2_score]\n","    )\n","\n","model.summary()\n","\n","# --- 3. Calculate Steps and Conditionally Run Training ---\n","num_train_samples = len(df[df[\"Split\"] == \"TRAIN\"])\n","num_val_samples = len(df[df[\"Split\"] == \"VAL\"])\n","steps_per_epoch = num_train_samples // BATCH_SIZE\n","val_steps = num_val_samples // BATCH_SIZE\n","\n","if resume_epoch < EPOCHS:\n","    print(f\"\\n--- Starting/Resuming Training from epoch {resume_epoch} ---\")\n","    start_time = time.time()\n","    history = model.fit(\n","        train_ds,\n","        epochs=EPOCHS,\n","        initial_epoch=resume_epoch, # This tells 'fit' where to start\n","        steps_per_epoch=steps_per_epoch,\n","        validation_data=val_ds,\n","        validation_steps=val_steps,\n","        callbacks=callbacks\n","    ).history\n","    end_time = time.time()\n","else:\n","    print(f\"\\n--- Training already completed to {EPOCHS} epochs. Skipping. ---\")\n","    # If training is done, load history from the log file for the evaluation block\n","    history_df = pd.read_csv(log_file)