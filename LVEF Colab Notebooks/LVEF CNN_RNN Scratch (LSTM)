(1024**3)\n","    else:\n","         max_ram_gb = 0.0 # Or np.nan\n","\n","metrics_path = os.path.join(experiment_dir, \"evaluation_metrics.txt\")\n","with open(metrics_path, 'w') as f:\n","    f.write(f\"Evaluation Metrics for Run: {run_name}\\n\"); f.write(\"=\"*40 + \"\\n\\n\")\n","    f.write(f\"Total Training Time: {readable_total_time}\\n\")\n","    f.write(f\"Average Time per Epoch: {avg_time_per_epoch:.2f} seconds\\n\")\n","    f.write(f\"Maximum RAM Used: {max_ram_gb:.2f} GB\\n\\n\")\n","    f.write(\"Validation Set Metrics:\\n\"); f.write(f\"  - RMSE: {val_results['rmse']:.4f}\\n\"); f.write(f\"  - MAE: {val_results['mae']:.4f}\\n\"); f.write(f\"  - R^2: {val_r2:.4f}\\n\\n\")\n","    f.write(\"Test Set Metrics:\\n\"); f.write(f\"  - RMSE: {test_results['rmse']:.4f}\\n\"); f.write(f\"  - MAE: {test_results['mae']:.4f}\\n\"); f.write(f\"  - R^2: {test_r2:.4f}\\n\")\n","print(f\"SUCCESS: Generated 'evaluation_metrics.txt'.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"TjETVMaOosQy","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1762058272604,"user_tz":420,"elapsed":992,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"d6fa9316-ec5a-490f-af23-e883f49ad675"},"outputs":[{"output_type":"stream","name":"stdout","text":["SUCCESS: Generated 'performance_analysis_plot.png'.\n","\n","--- Generating Training History Plot ---\n","Training history plot saved to: /content/drive/My Drive/LVEF Prediction Models/CNN_RNN Scratch(LSTM)-Mixed1/training_history_plot.png\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# --- 1. Generate performance_analysis_plot.png (Updated Style) ---\n","plot_path = os.path.join(experiment_dir, \"performance_analysis_plot.png\")\n","y_true_flat, y_pred_flat = y_test_true.flatten(), y_test_pred.flatten()\n","fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n