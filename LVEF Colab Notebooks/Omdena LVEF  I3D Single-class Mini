odels/I3D Models/I3D Model Arch. Modifications/I3D Single-class D-7/final_history.csv\n"]}],"source":["# I3D model training and saving\n","\n","print(\"Training started:\", datetime.datetime.now())\n","\n","start_time = time.time()\n","\n","history = model.fit(\n","    train_ds,\n","    epochs=50,\n","    steps_per_epoch=steps_per_epoch,\n","    validation_data=val_ds,\n","    validation_steps=val_steps,\n","    callbacks=callbacks,\n","    verbose=1\n",")\n","\n","end_time = time.time()\n","\n","from sklearn.metrics import r2_score as sk_r2_score\n","\n","try:\n","    # Save the model in the recommended .keras format to avoid H5 legacy issues.\n","    final_model_path = os.path.join(experiment_dir, \"final_best_model.keras\")\n","    model.save(final_model_path)\n","\n","    history_csv_path = os.path.join(experiment_dir, \"final_history.csv\")\n","    pd.DataFrame(history.history).to_csv(history_csv_path, index=False)\n","\n","    # Print success message as requested.\n","    print(\"\\nSuccessfully saved folder and files AFTER training.\")\n","    print(f\"Model saved to: {final_model_path}\")\n","    print(f\"History saved to: {history_csv_path}\")\n","\n","except Exception as e:\n","    print(f\"\\nAn error occurred during post-training saving: {e}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"3H5ZEGH5cC00"},"outputs":[],"source":["# --- EVALUATION ---\n","# Load the best performing model. Loading the .keras format is more reliable.\n","# The 'custom_objects' are not needed when loading the native .keras format.\n","\n","# Reset validation dataset to not repeat\n","val_ds   = make_dataset(\"VAL\", shuffle=False, repeat=False)\n","\n","best_model = keras.models.load_model(final_model_path)\n","\n","# Evaluate on Test Set\n","print(\"\\n--- Evaluating on Test Set ---\")\n","test_results = best_model.evaluate(test_ds, return_dict=True)\n","\n","# Evaluate on Validation Set to get Val metrics\n","print(\"\\n--- Evaluating on Validation Set ---\")\n","val_results = best_model.evaluate(val_ds, return_dict=True)\n","\n","# Calculate R^2 on validation and test sets separately\n","print(\"\\n--- Calculating R^2 Scores ---\")\n","y_val_true = np.concatenate([y.numpy() for x, y in val_ds])\n","y_val_pred = best_model.predict(val_ds)\n","val_r2 = sk_r2_score(y_val_true, y_val_pred)\n","\n","y_test_true = np.concatenate([y.numpy() for x, y in test_ds])\n","y_test_pred = best_model.predict(test_ds)\n","test_r2 = sk_r2_score(y_test_true, y_test_pred)\n","\n","# Calculates and prints performance metrics\n","total_duration_seconds = end_time - start_time\n","num_epochs_run = len(history.history['loss'])\n","avg_time_per_epoch = total_duration_seconds / num_epochs_run\n","readable_total_time = str(datetime.timedelta(seconds=int(total_duration_seconds)))\n","max_ram_gb = memory_callback.max_memory / (1024**3)\n","\n","print(\"\\n--- Performance Metrics ---\")\n","print(f\"Total Training Time: {readable_total_time}\")\n","print(f\"Average Time per Epoch: {avg_time_per_epoch:.2f} seconds\")\n","print(f\"Maximum RAM Used: {max_ram_gb:.2f} GB\")\n","\n","# Print all model metrics\n","print(\"\\n--- Model Metrics ---\")\n","print(f\"Val RMSE was {val_results['rmse']:.2f}%\")\n","print(f\"Val MAE was {val_results['mae']:.2f}\")\n","print(f\"Val R^2 was {val_r2:.4f}\")\n","print(f\"Test RMSE was {test_results['rmse']:.2f}%\")\n","print(f\"Test MAE was {test_results['mae']:.4f}\")\n","print(f\"Test R^2 was {test_r2:.4f}\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Nj1UG7uqcXd3"},"outputs":[],"source":["import matplotlib.pyplot as plt\n","# Analysis plots\n","print(\"\\n--- Generating Analysis Plots ---\")\n","# y_true and y_pred are already calculated from the block above\n","# Ensure they are flat arrays for plotting\n","y_true = y_test_true.flatten()\n","y_pred = y_test_pred.flatten()\n","\n","# Create the plots\n","fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","\n","# Plot 1: Ground Truth vs. Pre