e()\n","def r2_score(y_true, y_pred):\n","    ss_res =  K.sum(K.square(y_true - y_pred))\n","    ss_tot = K.sum(K.square(y_true - K.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + K.epsilon())\n","\n","#@tf.keras.utils.register_keras_serializable()\n","#def weighted_r2_score(y_true, y_pred):\n","    #y_true_ef = to_ef_value(y_true)\n","    #y_pred_ef = to_ef_value(y_pred)\n","    #return r2_score(y_true_ef, y_pred_ef) # Re-uses r2_score function"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"E0l799HELt7s"},"outputs":[],"source":["# Because of large filesize we may need to import the image data into Python in batches.\n","# This can be done using batch generators.\n","\n","# No longer needed (kept for legacy)\n","\n","#def generate_data(filelist, img_path, gt_df):\n","    #while True:\n","        #for i in filelist:\n","            #if i.endswith(\".avi\"):\n","                # Only preprocesses videos into the cache once (15 min process)\n","                #cache_file = os.path.join(CACHE_DIR, i.replace(\".avi\", \".npy\"))\n","                #if os.path.exists(cache_file):\n","                    #resized_img = np.load(cache_file)               # (28,112,112)\n","                #else:\n","                    #vid = skvideo.io.vread(os.path.join(img_path, i), num_frames=28)[:, :, :, 0]\n","                    #resized_img = np.stack([cv2.resize(f, (112,112),\n","                                                       #interpolation=cv2.INTER_LINEAR)\n","                                             #for f in vid]).astype(\"float32\")/255.0\n","                    #np.save(cache_file, resized_img)\n","\n","                #print(i[:-4])\n","                #img = np.load(img_path + i)\n","                #img = skvideo.io.vread(img_path +'/'+ i)[:, :, :, 0]\n","                #img = img[:28]\n","                #resized_img = np.zeros((28,112,112))\n","                #for j,k in enumerate(img):\n","                    #resized_img[j,:,:] = cv2