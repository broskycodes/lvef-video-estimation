sorflow.keras.callbacks import Callback\n","\n","\n","#class LRFinder(Callback):\n","    #\"\"\"Callback that exponentially adjusts the learning rate after each training batch between start_lr and\n","    #end_lr for a maximum number of batches: max_step. The loss and learning rate are recorded at each step allowing\n","    #visually finding a good learning rate as per https://sgugger.github.io/how-do-you-find-a-good-learning-rate.html via\n","    #the plot method.\n","    #\"\"\"\n","\n","    #def __init__(self, start_lr: float = 1e-7, end_lr: float = 10, max_steps: int = 100, smoothing=0.9):\n","        #super(LRFinder, self).__init__()\n","        #self.start_lr, self.end_lr = start_lr, end_lr\n","        #self.max_steps = max_steps\n","        #self.smoothing = smoothing\n","        #self.step, self.best_loss, self.avg_loss, self.lr = 0, 0, 0, 0\n","        #self.lrs, self.losses = [], []\n","\n","    #def on_train_begin(self, logs=None):\n","        #self.step, self.best_loss, self.avg_loss, self.lr = 0, 0, 0, 0\n","        #self.lrs, self.losses = [], []\n","\n","    #def on_train_batch_begin(self, batch, logs=None):\n","        #self.lr = self.exp_annealing(self.step)\n","        #tf.keras.backend.set_value(self.model.optimizer.lr, self.lr)\n","\n","    #def on_train_batch_end(self, batch, logs=None):\n","     #   logs = logs or {}\n","     #   loss = logs.get('loss')\n","     #   step = self.step\n","     #   if loss:\n","            #self.avg_loss = self.smoothing * self.avg_loss + (1 - self.smoothing) * loss\n","            #smooth_loss = self.avg_loss / (1 - self.smoothing ** (self.step + 1))\n","            #self.losses.append(smooth_loss)\n","            #self.lrs.append(self.lr)\n","\n","            #if step == 0 or loss < self.best_loss:\n","                #self.best_loss = loss\n","\n","            #if smooth_loss > 4 * self.best_loss or tf.math.is_nan(smooth_loss):\n","                #self.model.stop_training = True\n","\n","        #if step == self.max_steps:\n","            #self.model.stop_training = True\n","\n","        #self.step += 1\n","\n","    #def exp_annealing(self, step):\n","    #    return self.start_lr * (self.end_lr / self.start_lr) ** (step * 1. / self.max_steps)\n","\n","    #def plot(self):\n","    #    fig, ax = plt.subplots(1, 1)\n","    #    ax.set_ylabel('Loss')\n","    #    ax.set_xlabel('Learning Rate (log scale)')\n","     #   ax.set_xscale('log')\n","     #   ax.xaxis.set_major_formatter(plt.FormatStrFormatter('%.0e'))\n","     #   ax.plot(self.lrs, self.losses)\n","\n","        # Add a dot to the plot at the minimum loss\n","     #   min_loss_index = np.argmin(self.losses)\n","     #   min_lr = self.lrs[min_loss_index]\n","     #   min_loss = self.losses[min_loss_index]\n","     #   ax.plot(min_lr, min_loss, 'ro')\n","\n","        # Print the optimal learning rate\n","     #   print(\"Optimal learning rate: {:.2e}\".format(min_lr))"]},{"cell_type":"markdown","metadata":{"collapsed":false,"id":"KrXX0AQyLt7t"},"source":["##  I3D (Inflated 3D ConvNets)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"ZPYwMdqGLt7t"},"outputs":[],"source":["import tensorflow as tf\n","from tensorflow import keras\n","from tensorflow.keras import layers\n","\n","def conv3d(x, filters, kernel_size, strides=(1, 1, 1), padding='same', use_bias=False, name=None):\n","    \"\"\"A block that performs Conv3D -> LayerNormalization -> ReLU.\"\"\"\n","    x = layers.Conv3D(filters, kernel_size, strides=strides, padding=padding, use_bias=use_bias, name=name)(x)\n","    x = layers.LayerNormalization()(x)\n","    return layers.ReLU()(x)\n","\n","def i3d_inception_module(x, filters_1x1x1, filters_3x3x3_reduce, filters_3x3x3, filters_3x3x3_double_reduce, filters_3x3x3_double, filters_pool_proj, name=None):\n","    # 1x1x1\n","    branch1x1x1 = conv3d(x, filters_1x1x1, kernel_size=(1, 1, 1))\n","\n","    # 1x1x1 -> 3x3x3\n","    branch3x3x3 = conv3d(x, filters_3x3x3_reduce, kernel_size=(1, 1, 1))\n","    branch3x3x3 = conv3d(branch3x3x3, filters_3x3x3, kernel_size=(3, 3, 3))\n","\n","    # 1x1x1 -> 3x3x3 -> 3x3x3\n","    branch3x3x3dbl = conv3d(x, filters_3x3x3_double_reduce, kernel_size=(1, 1, 1))\n","    branch3x3x3dbl = conv3d(branch3x3x3dbl, filters_3x3x3_double, kernel_size=(3, 3, 3))\n","    branch3x3x3dbl = conv3d(branch3x3x3dbl, filters_3x3x3_double, kernel_size=(3, 3, 3))\n","\n","    # 3x3x3 (max pooling) -> 1x1x1\n","    branch_pool = layers.MaxPooling3D(pool_size=(3, 3, 3), strides=(1, 1, 1), padding='same')(x)\n","    branch_pool = conv3d(branch_pool, filters_pool_proj, kernel_size=(1, 1, 1))\n","\n","    return layers.concatenate([branch1x1x1, branch3x3x3, branch3x3x3dbl, branch_pool], axis=-1, name=name)\n","\n","# Under an ablation study\n","def build_i3d(num_classes, input_shape, dropout_rate):\n","    inputs = layers.Input(shape=input_shape)\n","\n","    # Stem\n","    x = layers.Conv3D(64, kernel_size=(7, 7, 7), strides=(2, 2, 2), padding='same', name='conv1')(inputs)\n","    x = layers.LayerNormalization(name='bn_conv1')(x)\n","    x = layers.Activation('relu')(x)\n","    x = layers.MaxPooling3D(pool_size=(1, 3, 3), strides=(1, 2, 2), padding='same', name='pool1')(x)\n","\n","    x = layers.Conv3D(192, kernel_size=(3, 3, 3), strides=(1, 1, 1), padding='same', name='conv2')(x) # 3x3x3\n","    x = layers.MaxPooling3D(pool_size=(1, 3, 3), strides=(1, 2, 2), padding='same', name='pool2')(x)\n","\n","    # Inception module 3\n","    x = i3d_inception_module(x, 64, 96, 128, 16, 32, 32, name='inception_3a')\n","    x = i3d_inception_module(x, 128, 128, 192, 32, 96, 64, name='inception_3b')\n","    x = layers.MaxPooling3D(pool_size=(3, 3, 3), strides=(2, 2, 2), padding='same', name='pool3')(x)\n","\n","    # Inception module 4\n","    x = i3d_inception_module(x, 192, 96, 208, 16, 48, 64, name='inception_4a')\n","    x = i3d_inception_module(x, 160, 112, 224, 24, 64, 64, name='inception_4b')\n","    x = i3d_inception_module(x, 128, 128, 256, 24, 64, 64, name='inception_4c')\n","    x = i3d_inception_module(x, 112, 144, 288, 32, 64, 64, name='inception_4d')\n","    x = i3d_inception_module(x, 256, 160, 320, 32, 128, 128, name='inception_4e')\n","    x = layers.MaxPooling3D(pool_size=(2, 3, 3), strides=(2, 2, 2), padding='same', name='pool4')(x)\n","\n","    # Inception module 5\n","    x = i3d_inception_module(x, 256, 160, 320, 32, 128, 128, name='inception_5a')\n","    x = i3d_inception_module(x, 384, 192, 384, 48, 128, 128, name='inception_5b')\n","    x = layers.AveragePooling3D(pool_size=(2, 4, 4), strides=(1, 1, 1), padding='valid', name='pool5')(x)\n","\n","    # Regression Head (original)\n","    #x = layers.Dropout(dropout_rate, name='dropout')(x)\n","    #x = layers.Flatten(name='flatten')(x)\n","    #outputs = layers.Dense(num_classes, activation='linear', name='predictions', dtype='float32')(x)\n","\n","    # Regression Head (A)\n","    x = layers.GlobalAveragePooling3D()(x)\n","    x = layers.Dropout(dropout_rate)(x)\n","    outputs = layers.Dense(1, activation='linear', name='predictions', dtype='float32')(x)\n","\n","    # Regression Head (B)\n","    #x = layers.Dropout(dropout_rate)(x)\n","    #x = layers.Conv3D(1, (1, 1, 1), padding='valid', activation='linear')(x)\n","    #outputs = layers.GlobalAveragePooling3D(dtype=\"float32\")(x)\n","\n","    # Regression Head (C)\n","    #x = layers.GlobalAveragePooling3D()(x)\n","    #x = layers.Dense(256, activation='relu')(x)\n","    #x = layers.Dropout(dropout_rate)(x)\n","    #outputs = layers.Dense(1, activation='linear', name='predictions', dtype='float32')(x)\n","\n","    # Build and return the model\n","    model = keras.Model(inputs, outputs, name='i3d')\n","    return model"]},{"cell_type":"markdown","metadata":{"collapsed":false,"id":"x_yA8yHRLt7t"},"source":["## Temporal Segment Network (TSN)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"AetQqB2FLt7t"},"outputs":[],"source":["#from tensorflow.keras.applications.resnet50 import Re