{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"MCuRdfQuofJQ","outputId":"67d6b2e1-7e47-4c96-d3fb-36357524ee7f"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Downloading from https://www.kaggle.com/api/v1/datasets/download/syxlicheng/heartdatabase?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":[" 34%|███▍      | 2.23G/6.56G [01:47<03:10, 24.3MB/s]"]}],"source":["import os\n","import datetime\n","import time\n","import psutil\n","import tensorflow as tf\n","from tensorflow import keras\n","import pandas as pd\n","import numpy as np\n","from sklearn.metrics import r2_score as sk_r2_score\n","import matplotlib.pyplot as plt\n","from tqdm import tqdm\n","from google.colab import drive\n","import kagglehub\n","\n","# --- Mount Google Drive & Import Data ---\n","drive.mount('/content/drive', force_remount=True)\n","heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-i3d-regression-tfrecord-files')\n","print('Kaggle data sources imported successfully.')"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"BuLcrg74oghA"},"outputs":[],"source":["# --- Configuration ---\n","DATA_PATH = os.path.join(heartdatabase_path, \"EchoNet-Dynamic\")\n","TFRECORD_PATH = tfrecord_files_path\n","DRIVE_SAVE_PATH = \"/content/drive/My Drive/LVEF Prediction Models/CNN_RNN Models\"\n","FRAMES, SIZE = 28, 112\n","BATCH_SIZE = 4\n","EPOCHS = 50\n","\n","# --- Performance Optimizations ---\n","tf.keras.mixed_precision.set_global_policy('mixed_float16')\n","tf.config.optimizer.set_jit(True)\n","print(\"TensorFlow performance optimizations enabled.\")\n","\n","df = pd.read_csv(os.path.join(DATA_PATH, \"FileList.csv\"))\n","print(f\"Metadata loaded for {len(df)} videos.\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"MH68UBGyoimE"},"outputs":[],"source":["def _parse_regression_tfrecord(example):\n","    \"\"\"Parses a single tf.train.Example proto for regression.\"\"\"\n","    feature_description = {\n","        'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","        'label_ef': tf.io.FixedLenFeature([], tf.float32),\n","    }\n","    example = tf.io.parse_single_example(example, feature_description)\n","    clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","    # Reshape to 1-channel video for our custom CNN\n","    clip = tf.reshape(clip, [FRAMES, SIZE, SIZE, 1])\n","    return clip, example['label_ef']\n","\n","def make_dataset(split_name, shuffle=False, repeat=False):\n","    \"\"\"Creates a tf.data.Dataset from a .tfrecord file.\"\"\"\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}.tfrecord\")\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle:\n","        dataset_size = len(df[df[\"Split\"] == split_name])\n","        dataset = dataset.shuffle(buffer_size=dataset_size)\n","    if repeat:\n","        dataset = dataset.repeat()\n","    dataset = dataset.map(_parse_regression_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","# --- Create the datasets ---\n","train_ds = make_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_ds   = make_dataset(\"VAL\", shuffle=False, repeat=True)\n","print(\"TFRecord data pipelines created successfully.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"LRVOgy9boi0p"},"outputs":[],"source":["# --- NEW: 3D Convolution and Inception Modules ---\n","def conv3d_ln(x, filters, kernel_size, strides=(1, 1, 1), padding='same', use_bias=False, name=None):\n","    \"\"\"Utility function to apply 3D conv + LN + ReLU.\"\"\"\n","    x = keras.layers.Conv3D(filters, kernel_size, strides=strides, padding=padding, use_bias=use_bias, name=name)(x)\n","    x = keras.layers.LayerNormalization()(x)\n","    return keras.layers.ReLU()(x)\n","\n","def i3d_inception_module(x, f1, f2_in, f2_out, f3_in, f3_out, f4_out, name=None):\n","    \"\"\"3D Inception module, based on your I3D reference script.\"\"\"\n","    # This is a 3D version of the i2d_inception_module\n","    branch1x1 = conv3d_ln(x, f1, (1, 1, 1))\n","\n","    branch3x3 = conv3d_ln(x, f2_in, (1, 1, 1))\n","    branch3x3 = conv3d_ln(branch3x3, f2_out, (3, 3, 3))\n","\n","    branch3x3dbl = conv3d_ln(x, f3_in, (1, 1, 1))\n","    branch3x3dbl = conv3d_ln(branch3x3dbl, f3_out, (3, 3, 3))\n","    branch3x3dbl = conv3d_ln(branch3x3dbl, f3_out, (3, 3, 3))\n","\n","    branch_pool = keras.layers.MaxPooling3D((3, 3, 3), strides=(1, 1, 1), padding='same')(x)\n","    branch_pool = conv3d_ln(branch_pool, f4_out, (1, 1, 1))\n","\n","    return keras.layers.concatenate([branch1x1, branch3x3, branch3x3dbl, branch_pool], axis=-1, name=name)\n","\n","def build_i3d_model():\n","    \"\"\"Builds the custom I3D-mini model, trained from scratch.\"\"\"\n","\n","    # The input is a 5D video tensor\n","    video_input = keras.Input(shape=(FRAMES, SIZE, SIZE, 1), name=\"video_input\")\n","\n","    # Stem - using 3D layers\n","    x = conv3d_ln(video_input, 64, (7, 7, 7), strides=(2, 2, 2), name='conv1')\n","    x = keras.layers.MaxPooling3D(pool_size=(1, 3, 3), strides=(1, 2, 2), padding='same', name='pool1')(x)\n","    x = conv3d_ln(x, 192, (3, 3, 3), name='conv2')\n","    x = keras.layers.MaxPooling3D(pool_size=(1, 3, 3), strides=(1, 2, 2), padding='same', name='pool2')(x)\n","\n","    # Inception modules (using 3D versions)\n","    x = i3d_inception_module(x, 64, 96, 128, 16, 32, 32, name='inception_3a')\n","    x = i3d_inception_module(x, 128, 128, 192, 32, 96, 64, name='inception_3b')\n","    x = keras.layers.MaxPooling3D(pool_size=(3, 3, 3), strides=(2, 2, 2), padding='same', name='pool3')(x)\n","\n","    # Get the shape of the tensor after the CNN base\n","    shape = x.shape\n","    # Reshape to (batch, frames, height * width * channels)\n","    x = keras.layers.Reshape((shape[1], shape[2] * shape[3] * shape[4]))(x)\n","\n","    # Add the LSTM layers from your reference\n","    x = keras.layers.LSTM(16, return_sequences=True)(x)\n","    x = keras.layers.LSTM(8)(x)\n","    x = keras.layers.Dropout(0.4)(x)\n","    x = keras.layers.Dense(8, activation=\"relu\")(x)\n","    output = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","\n","    model = keras.Model(video_input, output, name=\"i3d_from_scratch\")\n","    return model"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"dVE_PQSTojES"},"outputs":[],"source":["# --- 1. Setup Run Name, Directories, and Callbacks ---\n","run_name = \"LVEF CNN_RNN Scratch (3D)-1\"\n","experiment_dir = os.path.join(DRIVE_SAVE_PATH, run_name)\n","os.makedirs(experiment_dir, exist_ok=True)\n","print(f\"All outputs for this run will be saved in: {experiment_dir}\")\n","\n","def lr_step_decay(epoch, lr):\n","    \"\"\"\n","    Halves the learning rate every 10 epochs.\n","    \"\"\"\n","    initial_lr = 1e-3   # The starting learning rate\n","    drop_rate = 0.5     # The factor to multiply by\n","    epochs_drop = 10.0  # How often to apply the decay\n","\n","    new_lr = initial_lr * (drop_rate ** (epoch // epochs_drop))\n","    return new_lr\n","\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    ss_res =  keras.backend.sum(keras.backend.square(y_true - y_pred))\n","    ss_tot = keras.backend.sum(keras.backend.square(y_true - keras.backend.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + keras.backend.epsilon())\n","\n","class MemoryCallback(keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None): self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        mem_info = psutil.Process(os.getpid()).memory_info()\n","        self.max_memory = max(self.max_memory, mem_info.rss)\n","\n","memory_callback = MemoryCallback()\n","model_path = os.path.join(experiment_dir, \"best_model.keras\")\n","log_file = os.path.join(experiment_dir, \"training_log.csv\")\n","\n","callbacks = [\n","    keras.callbacks.ModelCheckpoint(\n","        filepath=model_path,\n","        monitor=\"val_rmse\", save_best_only=True, mode='min', verbose=1\n","    ),\n","    keras.callbacks.CSVLogger(log_file, append=True),\n","    keras.callbacks.EarlyStopping(\n","        monitor=\"val_rmse\", patience=20, restore_best_weights=True, verbose=1\n","    ),\n","    keras.callbacks.LearningRateScheduler(lr_step_decay, verbose=1),\n","    memory_callback\n","]\n","\n","# --- 2. Check for Existing Progress and Load or Build Model ---\n","try:\n","    # Try to read the last epoch from the log file\n","    log_data = pd.read_csv(log_file)\n","    resume_epoch = log_data['epoch'].iloc[-1] + 1\n","    print(f\"Log file found. Resuming training from epoch {resume_epoch}.\")\n","\n","    # Load the previously saved model\n","    model = keras.models.load_model(model_path, custom_objects={\"r2_score\": r2_score})\n","\n","except (FileNotFoundError, IndexError):\n","    # If no log file or it's empty, start a new run\n","    resume_epoch = 0\n","    print(\"No log file or model found. Starting a new training run from epoch 0.\")\n","\n","    # Build and compile a brand new model\n","    model = build_i3d_model()\n","    model.compile(\n","        optimizer=keras.optimizers.Adam(learning_rate=1e-3),\n","        loss='mse',\n","        metrics=[tf.keras.metrics.RootMeanSquaredError(name='rmse'), tf.keras.metrics.MeanAbsoluteError(name='mae'), r2_score]\n","    )\n","\n","model.summary()\n","\n","# --- 3. Calculate Steps and Conditionally Run Training ---\n","num_train_samples = len(df[df[\"Split\"] == \"TRAIN\"])\n","num_val_samples = len(df[df[\"Split\"] == \"VAL\"])\n","steps_per_epoch = num_train_samples // BATCH_SIZE\n","val_steps = num_val_samples // BATCH_SIZE\n","\n","if resume_epoch < EPOCHS:\n","    print(f\"\\n--- Starting/Resuming Training from epoch {resume_epoch} ---\")\n","    start_time = time.time()\n","    history = model.fit(\n","        train_ds,\n","        epochs=EPOCHS,\n","        initial_epoch=resume_epoch, # This tells 'fit' where to start\n","        steps_per_epoch=steps_per_epoch,\n","        validation_data=val_ds,\n","        validation_steps=val_steps,\n","        callbacks=callbacks\n","    ).history\n","    end_time = time.time()\n","else:\n","    print(f\"\\n--- Training already completed to {EPOCHS} epochs. Skipping. ---\")\n","    # If training is done, load history from the log file for the evaluation block\n","    history_df = pd.read_csv(log_file)\n","    # Convert DataFrame to the dictionary format Keras uses for plotting\n","    history = pd.read_csv(log_file).to_dict(orient='list')\n","    # Set timers to 0 as we can't know the original duration\n","    start_time, end_time = time.time(), time.time()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"572Eg9nlop4e"},"outputs":[],"source":["# --- 1. Save the Final Model ---\n","final_model_path = os.path.join(experiment_dir, \"final_model.keras\")\n","model.save(final_model_path)\n","print(f\"\\nFinal model saved to: {final_model_path}\")\n","\n","# --- 2. Load Best Model and Evaluate ---\n","print(\"\\n--- Starting Evaluation ---\")\n","best_model_path = os.path.join(experiment_dir, \"best_model.keras\")\n","best_model = keras.models.load_model(best_model_path, custom_objects={\"r2_score\": r2_score})\n","\n","test_ds_eval = make_dataset(\"TEST\", shuffle=False, repeat=False)\n","val_ds_eval = make_dataset(\"VAL\", shuffle=False, repeat=False)\n","\n","test_results = best_model.evaluate(test_ds_eval, return_dict=True, verbose=0)\n","val_results = best_model.evaluate(val_ds_eval, return_dict=True, verbose=0)\n","\n","y_val_true = np.concatenate([y.numpy() for x, y in val_ds_eval])\n","y_val_pred = best_model.predict(val_ds_eval)\n","val_r2 = sk_r2_score(y_val_true, y_val_pred)\n","\n","y_test_true = np.concatenate([y.numpy() for x, y in test_ds_eval])\n","y_test_pred = best_model.predict(test_ds_eval)\n","test_r2 = sk_r2_score(y_test_true, y_test_pred)\n","\n","# --- 3. Generate evaluation_metrics.txt ---\n","total_duration_seconds = end_time - start_time\n","num_epochs_run = len(history['loss'])\n","avg_time_per_epoch = total_duration_seconds / num_epochs_run if num_epochs_run > 0 else 0\n","readable_total_time = str(datetime.timedelta(seconds=int(total_duration_seconds)))\n","max_ram_gb = memory_callback.max_memory / (1024**3)\n","\n","metrics_path = os.path.join(experiment_dir, \"evaluation_metrics.txt\")\n","with open(metrics_path, 'w') as f:\n","    f.write(f\"Evaluation Metrics for Run: {run_name}\\n\"); f.write(\"=\"*40 + \"\\n\\n\")\n","    f.write(f\"Total Training Time: {readable_total_time}\\n\")\n","    f.write(f\"Average Time per Epoch: {avg_time_per_epoch:.2f} seconds\\n\")\n","    f.write(f\"Maximum RAM Used: {max_ram_gb:.2f} GB\\n\\n\")\n","    f.write(\"Validation Set Metrics:\\n\"); f.write(f\"  - RMSE: {val_results['rmse']:.4f}\\n\"); f.write(f\"  - MAE: {val_results['mae']:.4f}\\n\"); f.write(f\"  - R^2: {val_r2:.4f}\\n\\n\")\n","    f.write(\"Test Set Metrics:\\n\"); f.write(f\"  - RMSE: {test_results['rmse']:.4f}\\n\"); f.write(f\"  - MAE: {test_results['mae']:.4f}\\n\"); f.write(f\"  - R^2: {test_r2:.4f}\\n\")\n","print(f\"SUCCESS: Generated 'evaluation_metrics.txt'.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"TjETVMaOosQy"},"outputs":[],"source":["# --- 1. Generate performance_analysis_plot.png ---\n","plot_path = os.path.join(experiment_dir, \"performance_analysis_plot.png\")\n","y_true_flat, y_pred_flat = y_test_true.flatten(), y_test_pred.flatten()\n","fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","axes[0].scatter(y_true_flat, y_pred_flat, alpha=0.5); axes[0].plot([y_true_flat.min(), y_true_flat.max()], [y_true_flat.min(), y_true_flat.max()], '--', lw=2, color='red'); axes[0].set_xlabel(\"Ground Truth EF (%)\"); axes[0].set_ylabel(\"Predicted EF (%)\"); axes[0].set_title(\"Prediction vs. Ground Truth\"); axes[0].grid(True)\n","mean = np.mean([y_true_flat, y_pred_flat], axis=0); diff = y_true_flat - y_pred_flat; md, sd = np.mean(diff), np.std(diff)\n","axes[1].scatter(mean, diff, alpha=0.5); axes[1].axhline(md, color='gray', linestyle='--'); axes[1].axhline(md + 1.96 * sd, color='red', linestyle='--'); axes[1].axhline(md - 1.96 * sd, color='red', linestyle='--'); axes[1].set_xlabel(\"Average of GT and Prediction\"); axes[1].set_ylabel(\"Difference (GT - Prediction)\"); axes[1].set_title(\"Bland-Altman Plot\"); axes[1].grid(True)\n","plt.suptitle(f\"Performance Analysis for {run_name} (Test Set)\"); plt.tight_layout(rect=[0, 0.03, 1, 0.95]); fig.savefig(plot_path); plt.close(fig)\n","print(f\"SUCCESS: Generated 'performance_analysis_plot.png'.\")\n","\n","# --- 2. Generate Training History Plot (Loss Curves) ---\n","print(\"\\n--- Generating Training History Plot ---\")\n","history_df = pd.DataFrame(history)\n","fig, ax = plt.subplots(1, 1, figsize=(10, 6))\n","ax.plot(history_df['loss'], label='Training Loss')\n","ax.plot(history_df['val_loss'], label='Validation Loss')\n","ax.set_title(f'Training and Validation Loss for {run_name}')\n","ax.set_xlabel('Epoch')\n","ax.set_ylabel('Loss (MSE)')\n","ax.legend()\n","ax.grid(True)\n","history_plot_path = os.path.join(experiment_dir, \"training_history_plot.png\")\n","fig.savefig(history_plot_path)\n","print(f\"Training history plot saved to: {history_plot_path}\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"uojpFlkGou2r"},"outputs":[],"source":["from google.colab import runtime\n","runtime.unassign()"]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"L4","machine_shape":"hm","provenance":[{"file_id":"1pn4hJjrGZsyHbo0NErwreDiYT0tyrfes","timestamp":1757292955329},{"file_id":"1zZQzxAEJWx4JPVnwb97tEsV8PEdOFdke","timestamp":1757186314