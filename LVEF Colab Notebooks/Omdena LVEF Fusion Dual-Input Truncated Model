, ZeroPadding3D, LayerNormalization,\n","                                     BatchNormalization, Activation, GlobalAveragePooling3D)\n","from tensorflow.keras.regularizers import l1_l2\n","from tensorflow.keras.callbacks import (ModelCheckpoint, CSVLogger, EarlyStopping,\n","                                        TensorBoard, LearningRateScheduler)\n","from sklearn.metrics import r2_score as sk_r2_score\n","from google.colab import drive\n","import kagglehub\n","import matplotlib.pyplot as plt\n","\n","# Suppress TensorFlow/Keras warnings for cleaner output\n","import warnings\n","warnings.filterwarnings(\"ignore\", category=UserWarning)\n","os.environ['TF_CPP_MIN_LOG_LEVEL'] = '2'\n","tf.get_logger().setLevel('ERROR')"],"metadata":{"id":"hCiOfz57uqDE"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- 2. KAGGLE DATASET CONNECTION ---\n","print(\"Connecting to Kaggle datasets...\")\n","drive.mount('/content/drive')\n","syxlicheng_heartdatabase_path = kagglehub.dataset_download('syxlicheng/heartdatabase')\n","shravansaranyan_lvef_two_stream_tfrecord_files_path = kagglehub.dataset_download('shravansaranyan/lvef-two-stream-tfrecord-files')\n","print(\"Dataset connection complete.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BH2JpJDMQNn1","executionInfo":{"status":"ok","timestamp":1760752179115,"user_tz":420,"elapsed":197312,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"b4784638-4095-49ca-cf69-cd2a4bc18cf6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Connecting to Kaggle datasets...\n","Mounted at /content/drive\n","Downloading from https://www.kaggle.com/api/v1/datasets/download/syxlicheng/heartdatabase?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 6.56G/6.56G [00:39<00:00, 177MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Downloading from https://www.kaggle.com/api/v1/datasets/download/shravansaranyan/lvef-two-stream-tfrecord-files?dataset_version_number=1...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 3.13G/3.13G [00:17<00:00, 192MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Dataset connection complete.\n"]}]},{"cell_type":"code","source":["# --- 3. GPU/TPU & PERFORMANCE SETUP ---\n","# Activate mixed precision for performance on compatible GPUs\n","mixed_precision.set_global_policy('mixed_float16')\n","# Activate XLA (Accelerated Linear Algebra) for graph optimization\n","tf.config.optimizer.set_jit(True)\n","\n","strategy = tf.distribute.get_strategy()\n","print(f\"Running on {strategy.num_replicas_in_sync} replicas\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sLBBz89JQNgj","executionInfo":{"status":"ok","timestamp":1760752179124,"user_tz":420,"elapsed":5,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"95db9a22-f11e-4e5b-c575-35114f9cb4ec"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Running on 1 replicas\n"]}]},{"cell_type":"code","source":["# --- 4. PATHS AND CONSTANTS ---\n","TFRECORD_DIR = shravansaranyan_lvef_two_stream_tfrecord_files_path\n","TRAIN_TFRECORD_PATH = f'{TFRECORD_DIR}/train.tfrecord'\n","VAL_TFRECORD_PATH = f'{TFRECORD_DIR}/val.tfrecord'\n","TEST_TFRECORD_PATH = f'{TFRECORD_DIR}/test.tfrecord'\n","CSV_PATH = os.path.join(syxlicheng_heartdatabase_path, 'EchoNet-Dynamic', 'FileList.csv')\n","\n","BATCH_SIZE = 4\n","IMG_HEIGHT = 112\n","IMG_WIDTH = 112\n","NUM_FRAMES = 28"],"metadata":{"id":"fT7uz_gmQNZy"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- 5. CUSTOM CALLBACKS & METRICS ---\n","class MemoryCallback(tf.keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        try:\n","            mem_info = tf.config.experimental.get_memory_info('GPU:0')\n","            current_mem = mem_info['peak']\n","        except (ValueError, IndexError):\n","            import psutil\n","            process = psutil.Process(os.getpid())\n","            current_mem = process.memory_info().rss\n","        if current_mem > self.max_memory:\n","            self.max_memory = current_mem\n","\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    import tensorflow.keras.backend as K\n","    ss_res = K.sum(K.square(y_true - y_pred))\n","    ss_tot = K.sum(K.square(y_true - K.mean(y_true)))\n","    return K.switch(K.equal(ss_tot, 0), K.zeros_like(ss_tot), 1 - ss_res / (ss_tot + K.epsilon()))"],"metadata":{"id":"eRTPUHzLQNSu"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- 6. DATA PIPELINE ---\n","feature_description = {\n","    'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","    'ef_label': tf.io.FixedLenFeature([], tf.float32),\n","}\n","\n","def create_dataset(tfrecord_path, batch_size, shuffle=True, repeat=False):\n","    ds = tf.data.TFRecordDataset(tfrecord_path, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle: ds = ds.shuffle(buffer_size=1024)\n","    if repeat: ds = ds.repeat()\n","\n","    def _parse_function(proto):\n","        example = tf.io.parse_single_example(proto, feature_description)\n","        clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","        clip = tf.ensure_shape(clip, (NUM_FRAMES, IMG_HEIGHT, IMG_WIDTH))\n","        clip = tf.expand_dims(clip, axis=-1)\n","        label = example['ef_label']\n","        return clip, label\n","\n","    ds = ds.map(_parse_function, num_parallel_calls=tf.data.AUTOTUNE)\n","\n","    def _generate_streams(clip, label):\n","        spatial_stream = clip\n","        temporal_stream = clip[1:, :, :, :] - clip[:-1, :, :, :]\n","        mean = tf.reduce_mean(temporal_stream)\n","        std = tf.math.reduce_std(temporal_stream)\n","        temporal_stream = (temporal_stream - mean) / tf.maximum(std, 1e-6)\n","        return (spatial_stream, temporal_stream), label\n","\n","    ds = ds.map(_generate_streams, num_parallel_calls=tf.data.AUTOTUNE)\n","    ds = ds.batch(batch_size)\n","    ds = ds.prefetch(buffer_size=tf.data.AUTOTUNE)\n","    return ds"],"metadata":{"id":"EiFsb6MkQNLn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- 7. MODEL ARCHITECTURE ---\n","\n","def build_inception_sub_block(input_tensor, filter_config, l1_reg, l2_reg, name_prefix=''):\n","    # NOTE: The l1_reg and l2_reg arguments are now ignored to match the I3D OG model.\n","    # reg = l1_l2(l1=l1_reg, l2=l2_reg) # This is no longer needed.\n","\n","    # --- Branch 0 ---\n","    # CHANGED: Removed activation and regularizer, added BatchNormalization and a separate ReLU layer.\n","    branch_0 = Conv3D(filter_config['b0'], (1, 1, 1), padding='same', name=f'{name_prefix}_b0')(input_tensor)\n","    branch_0 = BatchNormalization()(branch_0)\n","    branch_0 = Activation('relu')(branch_0)\n","\n","    # --- Branch 1 ---\n","    # CHANGED: Removed activation and regularizer, added BatchNormalization and a separate ReLU layer for each convolution.\n","    branch_1 = Conv3D(filter_config['b1_reduce'], (1, 1, 1), padding='same', name=f'{name_prefix}_b1_reduce')(input_tensor)\n","    branch_1 = BatchNormalization()(branch_1)\n","    branch_1 = Activation('relu')(branch_1)\n","    branch_1 = Conv3D(filter_config['b1'], (3, 3, 3), padding='same', name=f'{name_prefix}_b1')(branch_1)\n","    branch_1 = BatchNormalization()(branch_1)\n","    branch_1 = Activation('relu')(branch_1)\n","\n","    # --- Branch 2 ---\n","    # CHANGED: Removed activation and regularizer, added BatchNormalization and a separate ReLU layer for each convolution.\n","    branch_2 = Conv3D(filter_config['b2_reduce'], (1, 1, 1), padding='same', name=f'{name_prefix}_b2_reduce')(input_tensor)\n","    branch_2 = BatchNormalization()(branch_2)\n","    branch_2 = Activation('relu')(branch_2)\n","    branch_2 = Conv3D(filter_config['b2'], (3, 3, 3), padding='same', name=f'{name_prefix}_b2')(branch_2)\n","    branch_2 = BatchNormalization()(branch_2)\n","    branch_2 = Activation('relu')(branch_2)\n","\n","    # --- Branch 3 ---\n","    branch_3 = MaxPooling3D((3, 3, 3), strides=(1, 1, 1), padding='same', name=f'{name_prefix}_b3_pool')(input_tensor)\n","    # CHANGED: Removed activation and regularizer, added BatchNormalization and a separate ReLU layer.\n","    branch_3 = Conv3D(filter_config['b3_proj'], (1, 1, 1), padding='same', name=f'{name_prefix}_b3_proj')(branch_3)\n","    branch_3 = BatchNormalization()(branch_3)\n","    branch_3 = Activation('relu')(branch_3)\n","\n","    # --- Concatenate Branches ---\n","    return concatenate([branch_0, branch_1, branch_2, branch_3], axis=-1, name=f'{name_prefix}_concat')\n","\n","\n","def inception_module_3(input_tensor, l1_reg, l2_reg):\n","    filters_3a = {'b0': 64, 'b1_reduce': 96, 'b1': 128, 'b2_reduce': 16, 'b2': 32, 'b3_proj': 32}\n","    filters_3b = {'b0': 128, 'b1_reduce': 128, 'b1': 192, 'b2_reduce': 32, 'b2': 96, 'b3_proj': 64}\n","\n","    x = build_inception_sub_block(input_tensor, filters_3a, l1_reg, l2_reg, name_prefix='shared_inception_3a')\n","    x = build_inception_sub_block(x, filters_3b, l1_reg, l2_reg, name_prefix='shared_inception_3b')\n","\n","    return x\n","\n","\n","def build_shared_feature_extractor(input_shape, l1_reg, l2_reg):\n","    reg = l1_l2(l1=l1_reg, l2=l2_reg)\n","    input_tensor = Input(shape=input_shape)\n","\n","    # --- Stem (Modified to match the I3D architecture) ---\n","\n","    # CHANGED: kernel_size, strides, and activation placement. Removed kernel_regularizer.\n","    x = Conv3D(64, (7, 7, 7), strides=(2, 2, 2), padding='same', name='shared_stem_conv1')(input_tensor)\n","    # CHANGED: LayerNormalization replaced with BatchNormalization\n","    x = BatchNormalization(name='shared_stem_norm1')(x)\n","    # CHANGED: Activation is now a separate layer.\n","    x = Activation('relu', name='shared_stem_relu1')(x)\n","    x = MaxPooling3D((1, 3, 3), strides=(1, 2, 2), padding='same', name='shared_stem_pool1')(x)\n","\n","    # CHANGED: kernel_size, strides, and activation. Removed kernel_regularizer.\n","    x = Conv3D(192, (1, 1, 1), strides=(1, 1, 1), padding='same', name='shared_stem_conv2')(x)\n","    # REMOVED: The second normalization and activation layers are removed to match the high-performing I3D stem.\n","\n","    # NEW: Added the final MaxPooling3D layer to match the I3D stem.\n","    x = MaxPooling3D((1, 3, 3), strides=(1, 2, 2), padding='same', name='shared_stem_pool2')(x)\n","\n","    # --- Inception Block ---\n","    x = inception_module_3(x, l1_reg, l2_reg)\n","\n","    return Model(inputs=input_tensor, outputs=x, name='shared_i3d_backbone')\n","\n","\n","def create_early_fusion_model(spatial_shape=(28, 112, 112, 1),\n","                              temporal_shape=(27, 112, 112, 1),\n","                              l1_reg=1e-5, l2_reg=1e-4, dropout_rate=0.5):\n","    \"\"\"\n","    Builds the model by fusing features directly after the I3D backbone\n","    and using a single, shared regression head.\n","    \"\"\"\n","    # --- Define Model Inputs ---\n","    spatial_input = Input(shape=spatial_shape, name='spatial_input')\n","    temporal_input = Input(shape=temporal_shape, name='temporal_input')\n","\n","    # Pad the temporal input to match the spatial input's frame count\n","    temporal_padded = ZeroPadding3D(padding=((1, 0), (0, 0), (0, 0)), name='temporal_padding')(temporal_input)\n","\n","    # --- Shared I3D Backbone ---\n","    # Both streams use the same feature extractor architecture\n","    shared_backbone = build_shared_feature_extractor(input_shape=spatial_shape, l1_reg=l1_reg, l2_reg=l2_reg)\n","\n","    spatial_features = shared_backbone(spatial_input)\n","    temporal_features = shared_backbone(temporal_padded)\n","\n","    # --- Early Fusion ---\n","    # The dedicated stream processing heads are removed.\n","    # Instead, we concatenate the feature maps from the backbones directly.\n","    fused_features = concatenate([spatial_features, temporal_features], axis=-1, name='early_channel_fusion')\n","\n","    # --- NEW, More Powerful Shared Regression Head ---\n","    reg = l1_l2(l1=l1_reg, l2=l2_reg)\n","    x = GlobalAveragePooling3D(name='fused_head_gap')(fused_features)\n","\n","    # Add a dense layer to learn complex feature interactions\n","    x = Dense(1024, activation='relu', kernel_regularizer=reg, name='fused_head_dense_1')(x)\n","\n","    x = Dropout(dropout_rate, name='fused_head_dropout')(x)\n","\n","    # Final output layer for regression\n","    final_output = Dense(1, activation='linear', dtype='float32', name=\"ef_output\")(x)\n","\n","    # --- Build Final Model ---\n","    return Model(inputs=[spatial_input, temporal_input], outputs=final_output, name='early_fusion_model')"],"metadata":{"id":"KOF60thsQNFN"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- 8. TRAINING SETUP ---\n","run_name = \"LVEF Fusion DIT-2\"\n","L1_REG = 1e-5\n","L2_REG = 1e-4\n","INITIAL_LR = 1e-4\n","EPOCHS = 50\n","PATIENCE = 20\n","\n","save_path = \"/content/drive/My Drive/LVEF Prediction Models\"\n","experiment_dir = os.path.join(save_path, run_name)\n","os.makedirs(experiment_dir, exist_ok=True)\n","print(f\"All outputs for this run will be saved in: {experiment_dir}\")\n","\n","df = pd.read_csv(CSV_PATH)\n","global_batch_size = BATCH_SIZE * strategy.num_replicas_in_sync\n","train_ds = create_dataset(TRAIN_TFRECORD_PATH, global_batch_size, shuffle=True, repeat=True)\n","val_ds = create_dataset(VAL_TFRECORD_PATH, global_batch_size, shuffle=False, repeat=False)\n","test_ds = create_dataset(TEST_TFRECORD_PATH, global_batch_size, shuffle=False, repeat=False)\n","\n","steps_per_epoch = len(df[df[\"Split\"] == \"TRAIN\"]) // global_batch_size\n","validation_steps = -(-len(df[df[\"Split\"] == \"VAL\"]) // global_batch_size)\n","test_steps = -(-len(df[df[\"Split\"] == \"TEST\"]) // global_batch_size)\n","print(f\"Steps: {steps_per_epoch} per epoch, {validation_steps} for validation, {test_steps} for test\")\n","\n","def step_decay(epoch):\n","    drop = 0.5\n","    epochs_drop = 10.0\n","    lr = INITIAL_LR * math.pow(drop, math.floor((epoch)/epochs_drop))\n","    return lr\n","\n","with strategy.scope():\n","    model = create_early_fusion_model(l1_reg=L1_REG, l2_reg=L2_REG, dropout_rate=0.5)\n","    optimizer = tf.keras.optimizers.Adam(clipnorm=1.0)\n","    model.compile(\n","        loss=tf.keras.losses.MeanSquaredError(),\n","        optimizer=optimizer,\n","        metrics=[\n","            tf.keras.metrics.RootMeanSquaredError(name=\"rmse\"),\n","            tf.keras.metrics.MeanAbsoluteError(name=\"mae\"),\n","            r2_score\n","        ]\n","    )\n","model.summary()\n","\n","memory_callback = MemoryCallback()\n","callbacks = [\n","    ModelCheckpoint(filepath=os.path.join(experiment_dir, \"best_model.keras\"), monitor=\"val_rmse\", save_best_only=True, mode='min', verbose=1),\n","    CSVLogger(os.path.join(experiment_dir, \"training_log.csv\")),\n","    EarlyStopping(monitor=\"val_loss\", patience=PATIENCE, min_delta=1e-3, restore_best_weights=True, verbose=1),\n","    TensorBoard(log_dir=os.path.join(experiment_dir, \"logs\")),\n","    LearningRateScheduler(step_decay, verbose=1),\n","    memory_callback\n","]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":597},"id":"2NkeFMclQM-c","executionInfo":{"status":"ok","timestamp":1760752182617,"user_tz":420,"elapsed":3484,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"ea6f616a-d084-461b-e6d6-da1c088ec933"},"executio