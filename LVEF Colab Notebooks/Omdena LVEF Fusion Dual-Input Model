n(experiment_dir, \"best_model.keras\")\n","    print(f\"\\n--- Loading best model from '{best_model_path}' for final evaluation ---\")\n","    best_model = tf.keras.models.load_model(best_model_path, custom_objects={'r2_score': r2_score})\n","\n","    print(\"\\n--- Evaluating Best Model ---\")\n","    val_results = best_model.evaluate(val_ds, steps=validation_steps, return_dict=True, verbose=0)\n","    test_results = best_model.evaluate(test_ds, steps=test_steps, return_dict=True, verbose=0)\n","\n","    print(\"--- Generating Predictions ---\")\n","    y_val_true = np.concatenate([y.numpy() for y in val_ds.map(lambda x, y: y)])\n","    y_val_pred = best_model.predict(val_ds, steps=validation_steps, verbose=0)\n","    val_r2 = sk_r2_score(y_val_true, y_val_pred)\n","    y_test_true = np.concatenate([y.numpy() for y in test_ds.map(lambda x, y: y)])\n","    y_test_pred = best_model.predict(test_ds, steps=test_steps, verbose=0)\n","    test_r2 = sk_r2_score(y_test_true, y_test_pred)\n","\n","    total_duration_seconds = end_time - start_time\n","    num_epochs_run = len(history.history['loss'])\n","    avg_time_per_epoch = total_duration_seconds / num_epochs_run if num_epochs_run > 0 else 0\n","    readable_total_time = str(timedelta(seconds=int(total_duration_seconds)))\n","    max_ram_gb = memory_callback.max_memory / (1024**3)\n","\n","    final_model_path = os.path.join(experiment_dir, \"final_model.keras\")\n","    shutil.copy(best_model_path, final_model_path)\n","\n","    plot_path = os.path.join(experiment_dir, \"performance_analysis_plot.png\")\n","    fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","    y_true_flat, y_pred_flat = y_test_true.flatten(), y_test_pred.flatten()\n","    axes[0].scatter(y_true_flat, y_pred_flat, alpha=0.5)\n","    axes[0].plot([y_true_flat.min(), y_true_flat.max()], [y_true_flat.min(), y_true_flat.max()], '--', lw=2, color='red')\n","    axes[0].set_xlabel(\"Ground Truth EF (%)\"), axes[0].set_ylabel(\"Predicted EF (%)\"), axes[0].set_title(\"Prediction vs. Ground Truth\")\n","    axes[0].grid(True)\n","    mean = np.mean([y_true_flat, y_pred_flat], axis=0)\n","    diff = y_true_flat - y_pred_flat\n","    md, sd = np.mean(diff), np.std(diff)\n","    axes[1].scatter(mean, diff, alpha=0.5)\n","    axes[1].axhline(md, color='gray', linestyle='--'), axes[1].axhline(md + 1.96 * sd, color='red', linestyle='--'), axes[1].axhline(md - 1.96 * sd, color='red', linestyle='--')\n","    axes[1].set_xlabel(\"Average of GT and Prediction\"), axes[1].set_ylabel(\"Difference (GT - Prediction)\"), axes[1].set_title(\"Bland-Altman Plot\")\n","    axes[1].grid(True)\n","    plt.suptitle(f\"Performance Analysis for {run_name} (Test Set)\"), plt.tight_layout(rect=[0, 0.03, 1, 0.95])\n","    fig.savefig(plot_path)\n","\n","    metrics_path = os.path.join(experiment_dir, \"evaluation_metrics.txt\")\n","    with open(metrics_path, 'w') as f:\n","        f.write(f\"Evaluation Metrics for Run: {run_name}\\n\"); f.write(\"=\"*40 + \"\\n\\n\")\n","        f.write(\"Performance Metrics:\\n\"); f.write(f\"  - Total Training Time: {readable_total_time}\\n\"); f.write(f\"  - Average Time per Epoch: {avg_time_per_epoch:.2f} seconds\\n\"); f.write(f\"  - Maximum RAM Used: {max_ram_gb:.2f} GB\\n\\n\")\n","        f.write(\"Validation Set Metrics (from best.keras):\\n\"); f.write(f\"  - RMSE: {val_results['rmse']:.4f}\\n\"); f.write(f\"  - MAE: {val_results['mae']:.4f}\\n\"); f.write(f\"  - Sklearn R^2: {val_r2:.4f}\\n\\n\")\n","        f.write(\"Test Set Metrics (from best.keras):\\n\"); f.write(f\"  - RMSE: {test_results['rmse']:.4f}\\n\"); f.write(f\"  - MAE: {test_results['mae']:.4f}\\n\"); f.write(f\"  - Sklearn R^2: {test_r2:.4f}\\n\")\n","\n","    print(\"\\n--- FINAL REPORT ---\")\n","    with open(metrics_path, 'r') as f:\n","        print(f.read())\n","    plt.show()\n","\n","except Exception as e:\n","    print(f\"\\nAn error occurred during post-training saving or evaluation: {e}\")"],"metadata":{"colab":{"base_