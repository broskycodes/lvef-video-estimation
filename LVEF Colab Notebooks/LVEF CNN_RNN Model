\n","\n","def make_dataset(split_name, shuffle=False, repeat=False):\n","    \"\"\"Creates a tf.data.Dataset from a .tfrecord file.\"\"\"\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}.tfrecord\")\n","\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle:\n","        dataset_size = len(df[df[\"Split\"] == split_name])\n","        dataset = dataset.shuffle(buffer_size=dataset_size)\n","\n","    if repeat:\n","        dataset = dataset.repeat()\n","\n","    dataset = dataset.map(_parse_regression_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","# --- Create the datasets ---\n","train_ds = make_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_ds   = make_dataset(\"VAL\", shuffle=False, repeat=True)\n","test_ds  = make_dataset(\"TEST\", shuffle=False, repeat=False)\n","\n","print(\"TFRecord data pipelines created successfully.\")\n","# Let's inspect a batch to confirm the shape is correct for the model\n","for videos, labels in train_ds.take(1):\n","    print(f\"Video batch shape: {videos.shape}\")\n","    print(f\"Label batch shape: {labels.shape}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"3MCJQ3w7VIns","executionInfo":{"status":"ok","timestamp":1755394131164,"user_tz":420,"elapsed":10875,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"220ac0f7-8247-4bb6-d9fb-2923046a4fa1"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["TFRecord data pipelines created successfully.\n","Video batch shape: (8, 28, 112, 112, 3)\n","Label batch shape: (8,)\n"]}]},{"cell_type":"code","source":["def build_cnnrnn_model():\n","    \"\"\"\n","    Builds the complete CNN-RNN model for LVEF regression.\n","    \"\"\"\n","    # --- 1. CNN Feature Extractor (InceptionV3) ---\n","    # Define the input shape for a single frame\n","    frame_input_shape = (SIZE, SIZE, 3)\n","\n","    # Base CNN model\n","    base_model = keras.applications.InceptionV3(\n","        weights=\"imagenet\" # Loading weights from ImageNet,\n","        include_top=False,\n","        pooling=\"avg\",\n","        input_shape=frame_input_shape,\n","    )\n","    # Pre-processing layer for Inceptionv3\n","    preprocess_input = keras.applications.inception_v3.preprocess_input\n","\n","    # Create a callable model from the base CNN and its pre-processing\n","    cnn_input = keras.Input(shape=frame_input_shape, name=\"cnn_input\")\n","    preprocessed = preprocess_input(cnn_input)\n","    outputs = base_cnn(preprocessed)\n","    feature_extractor = keras.Model(cnn_input, outputs, name=\"feature_extractor\")\n","\n","    # Set the feature extractor to be trainable ONLY for select models (for fine tuning)\n","    # First, ensure the whole base is frozen\n","    base_model.trainable = False\n","\n","    # Find the layer to start fine-tuning from\n","    fine_tune_at = 'mixed6'\n","    set_trainable = False\n","\n","    for layer in base_model.layers:\n","        if layer.name == fine_tune_at:\n","            set_trainable = True\n","        if set_trainable:\n","            layer.trainable = True\n","        else:\n","            layer.trainable = False\n","\n","    for layer in base_cnn.layers:\n","        if layer.name == fine_tune_at:\n","            set_trainable = True\n","        layer.trainable = set_trainable\n","\n","\n","    # --- 2. RNN Sequence Model (GRU) ---\n","    # The main model input is a sequence of frames (a video)\n","    video_input = keras.Input(shape=(FRAMES, SIZE, SIZE, 3), name=\"video_input\")\n","\n","    # Apply the feature extractor to each frame of the video\n","    # The output will be a sequence of feature vectors\n","    time_distributed_features = keras.layers.TimeDistributed(feature_extractor)(video_input)\n","\n","    # Process the sequence of features with GRU layers\n","    x = keras.layers.GRU(16, return_sequences=True)(time_distributed_features)\n","    x = keras.layers.GRU(8)(x)\n","    x = keras.layers.Dropout(0.4)(x) # Regularization\n","    x = keras.layers.Dense(8, activation=\"relu\")(x)\n","\n","    # --- 3. Regression Output ---\n","    # Final output layer for single-value LVEF regression\n","    output = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","\n","\n","    # --- 4. Create the final model ---\n","    model = keras.Model(video_input, output, name=\"cnn_rnn_lvef\")\n","\n","    return model\n","\n","    # Compilation for fine-tuning of CNN model\n","    model.compile(\n","    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-5), # Crucial for fine-tuning\n","    loss='mse',\n","    metrics=[\n","        tf.keras.metrics.RootMeanSquaredError(name='rmse'),\n","        tf.keras.metrics.MeanAbsoluteError(name='mae'),\n","        r2_score\n","        ]\n","    )\n","\n","# Build the model and print its summary to verify the architecture\n","model = build_cnnrnn_model()\n","model.summary()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":432},"id":"-o8OhHwuXNaE","executionInfo":{"status":"ok","timestamp":1755394139815,"user_tz":420,"elapsed":8647,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"8bd303e0-f83f-4e89-e2be-0e3caceee485"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading data from https://storage.googleapis.com/tensorflow/keras-applications/inception_v3/inception_v3_weights_tf_dim_ordering_tf_kernels_notop.h5\n","\u001b[1m87910968/87910968\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m5s\u001b[0m 0us/step\n"]},{"output_type":"display_data","data":{"text/plain":["\u001b[1mModel: \"cnn_rnn_lvef\"\u001b[0m\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier 