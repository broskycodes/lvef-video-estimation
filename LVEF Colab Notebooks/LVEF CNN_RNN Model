onsolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">21,802,784</span> (83.17 MB)\n","</pre>\n"]},"metadata":{}}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"uiR9BBiRcJrV","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1755394139835,"user_tz":420,"elapsed":18,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"f01b6be2-d06d-43b6-e270-35d7eed826d0"},"outputs":[{"output_type":"stream","name":"stdout","text":["Model compiled successfully for regression.\n"]}],"source":["# --- Custom Metric ---\n","# This is the custom R-squared metric, registered as a serializable Keras object\n","# so it can be saved and loaded with the model.\n","@tf.keras.utils.register_keras_serializable()\n","def r2_score(y_true, y_pred):\n","    ss_res =  keras.backend.sum(keras.backend.square(y_true - y_pred))\n","    ss_tot = keras.backend.sum(keras.backend.square(y_true - keras.backend.mean(y_true)))\n","    return 1 - ss_res/(ss_tot + keras.backend.epsilon())\n","\n","# --- Compile the Model ---\n","# We configure the model for regression.\n","model.compile(\n","    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-3),\n","    loss='mse', # Mean Squared Error is a standard loss for regression\n","    metrics=[\n","        tf.keras.metrics.RootMeanSquaredError(name='rmse'),\n","        tf.keras.metrics.MeanAbsoluteError(name='mae'),\n","        r2_score # Custom R^2 metric\n","    ]\n",")\n","\n","print(\"Model compiled successfully for regression.\")"]},{"cell_type":"code","source":["# --- Learning Rate Scheduler ---\n","def lr_step_decay(epoch, lr):\n","    \"\"\"Decays the learning rate by a factor of 0.5 every 10 epochs.\"\"\"\n","    initial_lr = 1e-3\n","    drop_rate = 0.5\n","    epochs_drop = 10.0\n","    new_lr = initial_lr * (drop_rate ** (epoch // epochs_drop))\n","    return new_lr\n","\n","# --- Custom Memory Callback ---\n","class MemoryCallback(keras.callbacks.Callback):\n","    def on_train_begin(self, logs=None):\n","        self.max_memory = 0\n","    def on_epoch_end(self, epoch, logs=None):\n","        mem_info = psutil.Process(os.getpid()).memory_info()\n","        current_memory = mem_info.rss\n","        self.max_memory = max(self.max_memory, current_memory)\n","\n","# --- Define Training Callbacks ---\n","# Define a unique name for this experiment run.\n","run_name = \"LVEF CNN_RNN-1\"\n","experiment_dir = os.path.join(DRIVE_SAVE_PATH, run_name)\n","os.makedirs(experiment_dir, exist_ok=True)\n","print(f\"All outputs for this run will be saved in: {experiment_dir}\")\n","\n","# Custom callback to track peak memory usage.\n","memory_callback = MemoryCallback()\n","callbacks = [\n","    # Checkpoint to save the best model based on validation RMSE.\n","    keras.callbacks.ModelCheckpoint(\n","        filepath=os.path.join(experiment_dir, \"best_model.keras\"),\n","        monitor=\"val_rmse\",\n","        save_best_only=True,\n","        mode='min',\n","        verbose=1\n","    ),\n","    # Logger for training history.\n","    keras.callbacks.CSVLogger(os.path.join(experiment_dir, \"training_log.csv\")),\n","    # Early stopping to prevent overfitting.\n","    keras.callbacks.EarlyStopping(\n","        monitor=\"val_rmse\",\n","        patience=20,\n","        min_delta=1e-3,\n","        restore_best_weights=True,\n","        verbose=1\n","    ),\n","    # TensorBoard callback.\n","    keras.callbacks.TensorBoard(\n","        log_dir=os.path.join(experiment_dir, \"logs/fit/\", datetime.datetime.now().strftime(\"%Y%m%d-%H%M%S\")),\n","        histogram_freq=0\n","    ),\n","    # Learning rate scheduler.\n","    keras.callbacks.LearningRateScheduler(lr_step_decay, verbose=1),\n","    memory_callback\n","]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"alf4B0DDhNT-","executionInfo":{"status":"ok","timestamp":1755