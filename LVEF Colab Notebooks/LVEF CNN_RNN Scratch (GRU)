= \"/content/drive/My Drive/LVEF Prediction Models/\"\n","FRAMES, SIZE = 28, 112\n","BATCH_SIZE = 4\n","EPOCHS = 50\n","\n","# --- Performance Optimizations ---\n","tf.keras.mixed_precision.set_global_policy('mixed_float16')\n","tf.config.optimizer.set_jit(True)\n","print(\"TensorFlow performance optimizations enabled.\")\n","\n","df = pd.read_csv(os.path.join(DATA_PATH, \"FileList.csv\"))\n","print(f\"Metadata loaded for {len(df)} videos.\")\n"]},{"cell_type":"code","execution_count":3,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":127,"status":"ok","timestamp":1762050395502,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"},"user_tz":420},"id":"MH68UBGyoimE","outputId":"794a25c2-319a-489b-9a5e-141e6d482f77"},"outputs":[{"output_type":"stream","name":"stdout","text":["TFRecord data pipelines created successfully.\n"]}],"source":["def _parse_regression_tfrecord(example):\n","    \"\"\"Parses a single tf.train.Example proto for regression.\"\"\"\n","    feature_description = {\n","        'clip_raw': tf.io.FixedLenFeature([], tf.string),\n","        'label_ef': tf.io.FixedLenFeature([], tf.float32),\n","    }\n","    example = tf.io.parse_single_example(example, feature_description)\n","    clip = tf.io.parse_tensor(example['clip_raw'], out_type=tf.float32)\n","    # Reshape to 1-channel video for our custom CNN\n","    clip = tf.reshape(clip, [FRAMES, SIZE, SIZE, 1])\n","    return clip, example['label_ef']\n","\n","def make_dataset(split_name, shuffle=False, repeat=False):\n","    \"\"\"Creates a tf.data.Dataset from a .tfrecord file.\"\"\"\n","    tfrecord_filename = os.path.join(TFRECORD_PATH, f\"{split_name.lower()}.tfrecord\")\n","    dataset = tf.data.TFRecordDataset(tfrecord_filename, num_parallel_reads=tf.data.AUTOTUNE)\n","    if shuffle:\n","        dataset_size = len(df[df[\"Split\"] == split_name])\n","        dataset = dataset.shuffle(buffer_size=dataset_size)\n","    if repeat:\n","        dataset = dataset.repeat()\n","    dataset = dataset.map(_parse_regression_tfrecord, num_parallel_calls=tf.data.AUTOTUNE)\n","    dataset = dataset.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n","    return dataset\n","\n","# --- Create the datasets ---\n","train_ds = make_dataset(\"TRAIN\", shuffle=True, repeat=True)\n","val_ds   = make_dataset(\"VAL\", shuffle=False, repeat=True)\n","print(\"TFRecord data pipelines created successfully.\")"]},{"cell_type":"code","execution_count":4,"metadata":{"executionInfo":{"elapsed":3,"status":"ok","timestamp":1762050395511,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"},"user_tz":420},"id":"LRVOgy9boi0p"},"outputs":[],"source":["def conv2d_bn(x, filters, kernel_size, strides=(1, 1), padding='same', use_bias=False, name=None):\n","    \"\"\"Utility function to apply conv + ln + ReLU.\"\"\"\n","    x = keras.layers.Conv2D(filters, kernel_size, strides=strides, padding=padding, use_bias=use_bias, name=name)(x)\n","    x = keras.layers.BatchNormalization()(x)\n","    return keras.layers.ReLU()(x)\n","\n","def conv2d_ln(x, filters, kernel_size, strides=(1, 1), padding='same', use_bias=False, name=None):\n","    \"\"\"Utility function to apply conv + ln + ReLU.\"\"\"\n","    x = keras.layers.Conv2D(filters, kernel_size, strides=strides, padding=padding, use_bias=use_bias, name=name)(x)\n","    x = keras.layers.LayerNormalization()(x)\n","    return keras.layers.ReLU()(x)\n","\n","def i2d_inception_module(x, f1, f2_in, f2_out, f3_in, f3_out, f4_out, name=None):\n","    \"\"\"2D Inception module, converted from your 3D version.\"\"\"\n","    branch1x1 = conv2d_bn(x, f1, (1, 1))\n","    branch3x3 = conv2d_bn(x, f2_in, (1, 1))\n","    branch3x3 = conv2d_bn(branch3x3, f2_out, (3, 3))\n","    branch3x3dbl = conv2d_bn(x, f3_in, (1, 1))\n","    branch3x3dbl = conv2d_bn(branch3x3dbl, f3_out, (3, 3))\n","    branch3x3dbl = conv2d_bn(branch3x3dbl, f3_out, (3, 3))\n","    branch_pool = keras.layers.MaxPooling2D((3, 3), strides=(1, 1), padding='same')(x)\n","    branch_pool = conv2d_bn(branch_pool, f4_out, (1, 1))\n","    return keras.layers.concatenate([branch1x1, branch3x3, branch3x3dbl, branch_pool], axis=-1, name=name)\n","\n","def build_i2d_rnn_model():\n","    \"\"\"Builds the custom I2D-RNN model, trained from scratch.\"\"\"\n","\n","    # --- 1. Define the CNN Feature Extractor (I2D-mini) ---\n","    frame_input = keras.Input(shape=(SIZE, SIZE, 1), name=\"frame_input\")\n","    x = conv2d_bn(frame_input, 64, (7, 7), strides=(2, 2), name='conv1')\n","    x = keras.layers.MaxPooling2D((3, 3), strides=(2, 2), padding='same', name='pool1')(x)\n","    x = conv2d_bn(x, 192, (3, 3), name='conv2')\n","    x = keras.layers.MaxPooling2D((3, 3), strides=(2, 2), padding='same', name='pool2')(x)\n","    x = i2d_inception_module(x, 64, 96, 128, 16, 32, 32, name='inception_3a')\n","    x = i2d_inception_module(x, 128, 128, 192, 32, 96, 64, name='inception_3b')\n","    x = keras.layers.MaxPooling2D((3, 3), strides=(2, 2), padding='same', name='pool3')(x)\n","    features = keras.layers.GlobalAveragePooling2D(name='global_avg_pool')(x)\n","    feature_extractor = keras.Model(frame_input, features, name=\"i2d_feature_extractor\")\n","\n","    # --- 2. Build the Full End-to-End Model ---\n","    video_input = keras.Input(shape=(FRAMES, SIZE, SIZE, 1), name=\"video_input\")\n","    time_distributed_features = keras.layers.TimeDistributed(feature_extractor)(video_input)\n","    x = keras.layers.GRU(16, return_sequences=True)(time_distributed_features)\n","    x = keras.layers.LayerNormalization()(x)\n","    x = keras.layers.GRU(8)(x)\n","    x = keras.layers.LayerNormalization()(x)\n","    x = keras.layers.Dropout(0.4)(x)\n","    x = keras.layers.Dense(8, activation=\"relu\")(x)\n","    output = keras.layers.Dense(1, activation=\"linear\", dtype='float32')(x)\n","\n","    model = keras.Model(video_input, output, name=\"i2d_rnn_model\")\n","    return model"]},{"cell_type":"code","execution_co