      # Save the result to a persistent file\n","        with open(os.path.join(experiment_dir, 'max_ram_usage.txt'), 'w') as f:\n","            f.write(str(max_ram_gb))\n","\n","memory_callback = MemoryCallback()\n","model_path = os.path.join(experiment_dir, \"best_model.keras\")\n","log_file = os.path.join(experiment_dir, \"training_log.csv\")\n","\n","callbacks = [\n","    keras.callbacks.ModelCheckpoint(\n","        filepath=model_path,\n","        monitor=\"val_rmse\", save_best_only=True, mode='min', verbose=1\n","    ),\n","    keras.callbacks.CSVLogger(log_file, append=True),\n","    keras.callbacks.EarlyStopping(\n","        monitor=\"val_rmse\", patience=20, restore_best_weights=True, verbose=1\n","    ),\n","    keras.callbacks.LearningRateScheduler(lr_step_decay, verbose=1),\n","    memory_callback\n","]\n","\n","# --- 2. Check for Existing Progress and Load or Build Model ---\n","try:\n","    # Try to read the last epoch from the log file\n","    log_data = pd.read_csv(log_file)\n","    resume_epoch = log_data['epoch'].iloc[-1] + 1\n","    print(f\"Log file found. Resuming training from epoch {resume_epoch}.\")\n","\n","    # Load the previously saved model\n","    model = keras.models.load_model(model_path, custom_objects={\"r2_score\": r2_score})\n","\n","except (FileNotFoundError, IndexError):\n","    # If no log file or it's empty, start a new run\n","    resume_epoch = 0\n","    print(\"No log file or model found. Starting a new training run from epoch 0.\")\n","\n","    # Build and compile a brand new model\n","    model = build_i2d_rnn_model()\n","    model.compile(\n","        optimizer=keras.optimizers.Adam(learning_rate=1e-3),\n","        loss='mse',\n","        metrics=[tf.keras.metrics.RootMeanSquaredError(name='rmse'), tf.keras.metrics.MeanAbsoluteError(name='mae'), r2_score]\n","    )\n","\n","model.summary()\n","\n","# --- 3. Calculate Steps and Conditionally Run Training ---\n","num_train_samples = len(df[df[\"Split\"] == \"TRAIN\"])\n","num_val_samples = len(df[df[\"Split\"] == \"VAL\"])\n","steps_per_epoch = num_train_samples // BATCH_SIZE\n","val_steps = num_val_samples // BATCH_SIZE\n","\n","if resume_epoch < EPOCHS:\n","    print(f\"\\n--- Starting/Resuming Training from epoch {resume_epoch} ---\")\n","    start_time = time.time()\n","    history = model.fit(\n","        train_ds,\n","        epochs=EPOCHS,\n","        initial_epoch=resume_epoch, # This tells 'fit' where to start\n","        steps_per_epoch=steps_per_epoch,\n","        validation_data=val_ds,\n","        validation_steps=val_steps,\n","        callbacks=callbacks\n","    ).history\n","    end_time = time.time()\n","else:\n","    print(f\"\\n--- Training already completed to {EPOCHS} epochs. Skipping. ---\")\n","    # If training is done, load history from the log file for the evaluation block\n","    history_df = pd.read_csv(log_file)\n","    # Convert DataFrame to the dictionary format Keras uses for plotting\n","    history = pd.read_csv(log_file).to_dict(orient='list')\n","    # Set timers to 0 as we can't know the original duration\n","    start_time, end_time = time.time(), time.time()"]},{"cell_type":"code","execution_count":6,"metadata":{"id":"572Eg9nlop4e","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1762056001770,"user_tz":420,"elapsed":127336,"user":{"displayName":"Shravan Saranyan","userId":"13270519625182089544"}},"outputId":"7771f682-1791-4933-de83-d12a3a1b986e"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Final model saved to: /content/drive/My Drive/LVEF Prediction Models/CNN_RNN Scratch(GRU)-Mixed1/final_model.keras\n","\n","--- Starting Evaluation ---\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/trainers/epoch_iterator.py:160: UserWarning: Your input ran out of data; interrupting training. Make sure that your dataset or generator can generate at least `steps_per_epoch * epochs` batches. 