 section_text, re.IGNORECASE)\n","            rmse = float(rmse_match.group(1)) if rmse_match else 'N/A'\n","            mae = float(mae_match.group(1)) if mae_match else 'N/A'\n","            r2 = float(r2_match.group(1)) if r2_match else 'N/A'\n","            return rmse, mae, r2\n","\n","        sections = re.split(r\"validation set metrics:|test set metrics:\", content, flags=re.IGNORECASE)\n","\n","        if len(sections) == 3:\n","            val_section_text, test_section_text = sections[1], sections[2]\n","            val_rmse, val_mae, val_r2 = parse_metrics_from_section(val_section_text)\n","            test_rmse, test_mae, test_r2 = parse_metrics_from_section(test_section_text)\n","            model_stats.update({\n","                'Val RMSE': val_rmse, 'Val MAE': val_mae, 'Val R^2': val_r2,\n","                'Test RMSE': test_rmse, 'Test MAE': test_mae, 'Test R^2': test_r2\n","            })\n","        else:\n","            for metric in ['Val RMSE', 'Val MAE', 'Val R^2', 'Test RMSE', 'Test MAE', 'Test R^2']:\n","                model_stats[metric] = 'N/A'\n","\n","        # Add the extracted data to our main list\n","        all_model_data.append(model_stats)\n","\n","    # --- 3. PARSING LOGIC (ROBUST VERSION) ---\n","# This dictionary will hold the extracted data for the current model\n","model_stats = {'Model Name': run_name}\n","\n","def parse_metrics_from_section(section_text):\n","    \"\"\"\n","    Extracts metrics (RMSE, MAE, R^2) from a given block of text.\n","    \"\"\"\n","    # Use re.search() to find the first match for each metric. The patterns are now simpler.\n","    # The 'r' prefix for the string ensures it's a raw string, fixing the SyntaxWarning.\n","    rmse_match = re.search(r\"RMSE:\\s*([\\d\\.]+)\", section_text)\n","    mae_match = re.search(r\"MAE:\\s*([\\d\\.]+)\", section_text)\n","    # This pattern looks for \"R^2\" or \"Sklearn R^2\"\n","    r2_match = re.search(r\"R\\^2:\\s*([\\d\\.]+)\", section_text, re.IGNORECASE)\n","\n","    # Extract the values if found, otherwise return 'N/A'\n","    rmse = float(rmse_match.group(1)) if rmse_match else 'N/A'\n","    mae = float(mae_match.group(1)) if mae_match else 'N/A'\n","    r2 = float(r2_match.group(1)) if r2_match else 'N/A'\n","\n","    return rmse, mae, r2\n","\n","# Split the file content into Validation and Test sections\n","# We use re.split with IGNORECASE to handle variations like \"Validation Set Metrics\"\n","sections = re.split(r\"validation set metrics:|test set metrics:\", content, flags=re.IGNORECASE)\n","\n","# The split will produce 3 parts: [before_val, val_section, test_section]\n","if len(sections) == 3:\n","    val_section_text = sections[1]\n","    test_section_text = sections[2]\n","\n","    # Parse each section\n","    val_rmse, val_mae, val_r2 = parse_metrics_from_section(val_section_text)\n","    test_rmse, test_mae, test_r2 = parse_metrics_from_section(test_section_text)\n","\n","    # Populate the stats dictionary\n","    model_stats['Val RMSE'] = val_rmse\n","    model_stats['Val MAE'] = val_mae\n","    model_stats['Val R^2'] = val_r2\n","    model_stats['Test RMSE'] = test_rmse\n","    model_stats['Test MAE'] = test_mae\n","    model_stats['Test R^2'] = test_r2\n","\n","else:\n","    # If the file format is unexpected, fill with N/A\n","    for metric in ['Val RMSE', 'Val MAE', 'Val R^2', 'Test RMSE', 'Test MAE', 'Test R^2']:\n","        model_stats[metric] = 'N/A'\n","\n","# Add the extracted data to our main list\n","all_model_data.append(model_stats)\n","\n","# --- 4. CREATE AND DISPLAY THE FINAL TABLE ---\n","# Convert the list of dictionaries into a pandas DataFrame\n","results_df = pd.DataFrame(all_model_data)\n","\n","# Ensure the columns are in the desired order\n","desired_columns = ['Model Name', 'Val RMSE', 'Val MAE', 'Val R^2', 'Test RMSE', 'Test MAE', 'Test R^2']\n","# Filter out any columns that weren't found, just in case\n","existing_columns = [col for col in desired_columns if col in results_df.columns]\n","results_df = results_df[existing_columns]\n","\n","\n","# Set the 'Model Name' as the index for better readability\n","results_df.set_index('Model Name', inplace=True)\n","\n","print(\"\\n\\n\" + \"=\"*50)\n","print(\"           MODEL RESULTS SUMMARY\")\n","print(\"=\"*50)\n","\n","# Display the final table\n","# In Colab, this will render as a nicely formatted interactive table\n","display(results_df)\n","\n","# You can also save this table to a CSV file\n","results_df.to_csv(os.path.join(MODELS_BASE_DIR, \"model_comparison_summary.csv\"))\n","print(\"\\nResults table also saved to 'model_comparison_summary.csv' in your base models directory.\")"]}]}